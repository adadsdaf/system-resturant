<Page x:Class="RestaurantMS.Desktop.Views.Kitchen.KitchenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft"
      Background="#0d1117">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- شريط أعلى -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="🔄  تحديث" Style="{StaticResource PrimaryButton}"
                    Padding="16,8" Click="BtnRefresh_Click" Margin="0,0,12,0"/>
            <Border Background="#21262d" CornerRadius="8" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="الطلبات المعلقة: " Foreground="#8b949e" FontSize="13"/>
                    <TextBlock x:Name="TxtPending" Text="0" Foreground="#f59e0b"
                               FontSize="13" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- بطاقات الطلبات -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="OrdersPanel" Orientation="Horizontal"/>
        </ScrollViewer>
    </Grid>
</Page>
