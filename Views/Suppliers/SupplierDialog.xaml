<Window x:Class="RestaurantMS.Desktop.Views.Suppliers.SupplierDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="#0d1117"
        Title="بيانات المورد" Height="340" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="إضافة مورد"
                   Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="اسم الشركة" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtCompany" Style="{StaticResource DarkInput}" Height="40" Margin="0,0,0,12"/>
            <TextBlock Text="اسم المسؤول" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtContact" Style="{StaticResource DarkInput}" Height="40" Margin="0,0,0,12"/>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="الهاتف" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtPhone" Style="{StaticResource DarkInput}" Height="40"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="البريد الإلكتروني" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtEmail" Style="{StaticResource DarkInput}" Height="40"/>
                </StackPanel>
            </Grid>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
            <Button Content="حفظ" Style="{StaticResource PrimaryButton}" Width="100" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="إلغاء" Style="{StaticResource GhostButton}" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
