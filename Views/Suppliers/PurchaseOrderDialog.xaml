<Window x:Class="RestaurantMS.Desktop.Views.Suppliers.PurchaseOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="{StaticResource BgBrush}"
        Title="طلب شراء جديد" Height="440" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="📋  طلب شراء جديد"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="المورد" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
            <ComboBox x:Name="CmbSupplier" Style="{StaticResource DarkCombo}" Height="42"
                      Margin="0,0,0,12"
                      DisplayMemberPath="company_name" SelectedValuePath="supplier_id"/>
            <TextBlock Text="المادة" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
            <ComboBox x:Name="CmbIngredient" Style="{StaticResource DarkCombo}" Height="42"
                      Margin="0,0,0,12"
                      DisplayMemberPath="Display" SelectedValuePath="ingredient_id"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="الكمية المطلوبة" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtQty" Style="{StaticResource DarkInput}" Height="42" Text="1"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="سعر الوحدة" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtPrice" Style="{StaticResource DarkInput}" Height="42" Text="0"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="تاريخ التسليم المتوقع" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
            <DatePicker x:Name="DpDelivery" Height="42" Margin="0,0,0,12"/>
            <TextBlock Text="ملاحظات" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtNotes" Style="{StaticResource DarkInput}" Height="42"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
            <Button Content="إرسال الطلب" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="إلغاء"        Style="{StaticResource GhostButton}"   Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
