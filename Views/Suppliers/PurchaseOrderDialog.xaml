<Window x:Class="RestaurantMS.Desktop.Views.Suppliers.PurchaseOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="#0d1117"
        Title="طلب شراء جديد" Height="420" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="📋  طلب شراء جديد"
                   Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="المورد" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbSupplier" Style="{StaticResource DarkCombo}" Height="40"
                      Margin="0,0,0,12" DisplayMemberPath="company_name" SelectedValuePath="supplier_id"/>
            <TextBlock Text="المادة" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbIngredient" Style="{StaticResource DarkCombo}" Height="40"
                      Margin="0,0,0,12" DisplayMemberPath="Display" SelectedValuePath="ingredient_id"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="الكمية المطلوبة" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtQty" Style="{StaticResource DarkInput}" Height="40" Text="1"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="سعر الوحدة" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtPrice" Style="{StaticResource DarkInput}" Height="40" Text="0"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="تاريخ التسليم المتوقع" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <DatePicker x:Name="DpDelivery" Height="40" Margin="0,0,0,12"/>
            <TextBlock Text="ملاحظات" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNotes" Style="{StaticResource DarkInput}" Height="40"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
            <Button Content="إرسال الطلب" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="إلغاء"        Style="{StaticResource GhostButton}"   Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
