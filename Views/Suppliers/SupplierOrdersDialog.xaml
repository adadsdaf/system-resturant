<Window x:Class="RestaurantMS.Desktop.Views.Suppliers.SupplierOrdersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="{StaticResource BgBrush}"
        Title="طلبات المورد" Height="480" Width="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtTitle" Grid.Row="0"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
        <DataGrid Grid.Row="1" x:Name="GridOrders" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"            Binding="{Binding po_id}"       Width="60"/>
                <DataGridTextColumn Header="الإجمالي"    Binding="{Binding total}"        Width="120"/>
                <DataGridTextColumn Header="الحالة"      Binding="{Binding status}"       Width="100"/>
                <DataGridTextColumn Header="تاريخ الطلب" Binding="{Binding created_fmt}"  Width="130"/>
                <DataGridTextColumn Header="تسليم متوقع" Binding="{Binding delivery_fmt}" Width="130"/>
                <DataGridTemplateColumn Header="استلام"  Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✅ استلمت" Tag="{Binding po_id}"
                                    Style="{StaticResource GhostButton}" FontSize="12"
                                    Click="BtnReceive_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
