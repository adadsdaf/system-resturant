<Page x:Class="RestaurantMS.Desktop.Views.Sales.SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft"
      Background="{StaticResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- فلاتر -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                <TextBlock Text="من:" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0" FontSize="13"/>
                <DatePicker x:Name="DpFrom" Width="130" Height="36" FontSize="13"
                            SelectedDateChanged="Filter_Changed"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                <TextBlock Text="إلى:" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0" FontSize="13"/>
                <DatePicker x:Name="DpTo" Width="130" Height="36" FontSize="13"
                            SelectedDateChanged="Filter_Changed"/>
            </StackPanel>
            <Button Content="🔄 تحديث" Style="{StaticResource GhostButton}" Click="BtnRefresh_Click"/>
        </StackPanel>

        <!-- إحصائيات سريعة -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="إجمالي المبيعات" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtTotal" Text="0.00" Foreground="{StaticResource AccentBrush}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="عدد الطلبات" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtCount" Text="0" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="متوسط الطلب" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtAvg" Text="0.00" Foreground="{StaticResource SuccessBrush}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="إجمالي الضريبة" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtTax" Text="0.00" Foreground="{StaticResource BlueBrush}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- الجدول -->
        <DataGrid Grid.Row="2" x:Name="GridOrders" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="رقم"         Binding="{Binding order_id}"      Width="70"/>
                <DataGridTextColumn Header="العميل"      Binding="{Binding customer_name}" Width="*"/>
                <DataGridTextColumn Header="الإجمالي"    Binding="{Binding total_fmt}"     Width="130"/>
                <DataGridTextColumn Header="طريقة الدفع" Binding="{Binding payment_method}" Width="120"/>
                <DataGridTextColumn Header="الكاشير"     Binding="{Binding served_by}"     Width="130"/>
                <DataGridTextColumn Header="التاريخ"     Binding="{Binding date_fmt}"      Width="160"/>
                <DataGridTemplateColumn Header="إجراءات" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="التفاصيل" Tag="{Binding order_id}"
                                    Style="{StaticResource GhostButton}" Height="28" FontSize="12"
                                    Click="BtnDetails_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
