<Page x:Class="RestaurantMS.Desktop.Views.Sales.SalesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft" Background="#0d1117">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- فلاتر -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                <TextBlock Text="من:" Foreground="#8b949e" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="13"/>
                <DatePicker x:Name="DpFrom" Width="130" Height="36"
                            Background="#21262d" Foreground="White" FontSize="13"
                            SelectedDateChanged="Filter_Changed"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                <TextBlock Text="إلى:" Foreground="#8b949e" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="13"/>
                <DatePicker x:Name="DpTo" Width="130" Height="36"
                            Background="#21262d" Foreground="White" FontSize="13"
                            SelectedDateChanged="Filter_Changed"/>
            </StackPanel>
            <Button Content="🔄 تحديث" Style="{StaticResource GhostButton}" Click="BtnRefresh_Click"/>
        </StackPanel>

        <!-- إحصائيات سريعة -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="إجمالي المبيعات" Foreground="#8b949e" FontSize="12"/>
                    <TextBlock x:Name="TxtTotal" Text="0.00" Foreground="#f59e0b" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="عدد الطلبات" Foreground="#8b949e" FontSize="12"/>
                    <TextBlock x:Name="TxtCount" Text="0" Foreground="White" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="متوسط الطلب" Foreground="#8b949e" FontSize="12"/>
                    <TextBlock x:Name="TxtAvg" Text="0.00" Foreground="#22c55e" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="إجمالي الضريبة" Foreground="#8b949e" FontSize="12"/>
                    <TextBlock x:Name="TxtTax" Text="0.00" Foreground="#a78bfa" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- الجدول -->
        <DataGrid Grid.Row="2" x:Name="GridOrders" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="رقم"         Binding="{Binding order_id}"      Width="70"/>
                <DataGridTextColumn Header="العميل"      Binding="{Binding customer_name}" Width="*"/>
                <DataGridTextColumn Header="المجموع"     Binding="{Binding total_fmt}"     Width="110"/>
                <DataGridTextColumn Header="الخصم"       Binding="{Binding disc_fmt}"      Width="90"/>
                <DataGridTextColumn Header="الضريبة"     Binding="{Binding tax_fmt}"       Width="90"/>
                <DataGridTextColumn Header="طريقة الدفع" Binding="{Binding payment_method}" Width="110"/>
                <DataGridTextColumn Header="الكاشير"     Binding="{Binding served_by}"     Width="120"/>
                <DataGridTextColumn Header="التاريخ"     Binding="{Binding date_fmt}"      Width="130"/>
                <DataGridTemplateColumn Header="إجراءات" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="تفاصيل" Tag="{Binding order_id}"
                                        Style="{StaticResource GhostButton}" FontSize="12"
                                        Margin="0,0,4,0" Click="BtnDetails_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
