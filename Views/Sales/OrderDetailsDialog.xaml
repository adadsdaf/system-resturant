<Window x:Class="RestaurantMS.Desktop.Views.Sales.OrderDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="#0d1117"
        Title="تفاصيل الطلب" Height="480" Width="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="TxtHeader" Foreground="White" FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Name="TxtInfo"   Foreground="#8b949e" FontSize="13" Margin="0,4,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="GridItems" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="الصنف"    Binding="{Binding item_name}" Width="*"/>
                <DataGridTextColumn Header="الكمية"   Binding="{Binding quantity}"  Width="70"/>
                <DataGridTextColumn Header="السعر"    Binding="{Binding unit_price}" Width="90"/>
                <DataGridTextColumn Header="الإجمالي" Binding="{Binding subtotal}"   Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <Separator Background="#334155" Margin="0,0,0,10"/>
            <TextBlock x:Name="TxtTotals" Foreground="White" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
