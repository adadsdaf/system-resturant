<Window x:Class="RestaurantMS.Desktop.Views.Sales.OrderDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="{StaticResource BgBrush}"
        Title="تفاصيل الطلب" Height="500" Width="540"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TxtHeader"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Name="TxtInfo"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="13" Margin="0,4,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="GridItems" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="الصنف"    Binding="{Binding item_name}" Width="*"/>
                <DataGridTextColumn Header="الكمية"   Binding="{Binding quantity}"  Width="70"/>
                <DataGridTextColumn Header="السعر"    Binding="{Binding unit_price}" Width="90"/>
                <DataGridTextColumn Header="الإجمالي" Binding="{Binding subtotal}"   Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,0,0,10"/>
            <TextBlock x:Name="TxtTotals"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="14" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
