<Page x:Class="RestaurantMS.Desktop.Views.Home.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft">

    <Grid>
        <!-- خلفية بيضاء/رمادية فاتحة مع تدرج خفيف -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0F4F8" Offset="0"/>
                <GradientStop Color="#E8EFF7" Offset="0.5"/>
                <GradientStop Color="#EDF2F7" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- موجات زخرفية خلفية (كما في الصورة المرجعية) -->
        <Canvas ClipToBounds="True">
            <!-- موجة يمين سفلى - زرقاء -->
            <Ellipse Canvas.Left="-120" Canvas.Top="200"
                     Width="600" Height="400"
                     Opacity="0.08" RenderTransformOrigin="0.5,0.5">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1B4E9E" Offset="0"/>
                        <GradientStop Color="#2563EB" Offset="1"/>
                    </LinearGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="-30"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- موجة يسار أعلى - برتقالية -->
            <Ellipse Canvas.Right="-80" Canvas.Top="-100"
                     Width="500" Height="350"
                     Opacity="0.07" RenderTransformOrigin="0.5,0.5">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F7941D" Offset="0"/>
                        <GradientStop Color="#FDB849" Offset="1"/>
                    </LinearGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="20"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- موجة وسط - زرقاء داكنة -->
            <Ellipse Canvas.Left="200" Canvas.Bottom="-80"
                     Width="700" Height="250"
                     Opacity="0.05">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#1B4E9E" Offset="1"/>
                    </LinearGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <!-- المحتوى الرئيسي -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- الشعار مع ظل -->
            <Border HorizontalAlignment="Center" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.18" Color="#1B4E9E"/>
                </Border.Effect>
                <Image Source="pack://application:,,,/Assets/itqansoft_logo.png"
                       Width="140" Height="140"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- اسم الشركة بنفس أسلوب الصورة -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                <TextBlock Text="it" Foreground="#1B4E9E" FontSize="34" FontWeight="Black"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="QAN" Foreground="#F7941D" FontSize="34" FontWeight="Black"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="S" Foreground="#1E293B" FontSize="34" FontWeight="Black"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="oft" Foreground="#64748B" FontSize="34" FontWeight="Light"
                           FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- وصف الشركة -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                <TextBlock Text="نظام المعلومات والحلول البرمجية"
                           Foreground="#475569" FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Information Systems and Software Solutions"
                           Foreground="#94A3B8" FontSize="10" FontFamily="Segoe UI"
                           HorizontalAlignment="Center" FlowDirection="LeftToRight"/>
            </StackPanel>

            <!-- خط فاصل متدرج -->
            <Border Height="2" Width="340" HorizontalAlignment="Center"
                    Margin="0,12,0,16" CornerRadius="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F7941D" Offset="0"/>
                        <GradientStop Color="#1B4E9E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- اسم النظام -->
            <TextBlock Text="نظام إدارة المطاعم"
                       Foreground="#1E293B" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Enterprise Resource Planning Solutions"
                       Foreground="#64748B" FontSize="12" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" Margin="0,0,0,20"
                       FlowDirection="LeftToRight"/>

            <!-- بطاقة معلومات المستخدم والترخيص -->
            <Border CornerRadius="12" Padding="28,18" HorizontalAlignment="Center"
                    MinWidth="380" Margin="0,0,0,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8FAFC" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F7941D" Offset="0"/>
                        <GradientStop Color="#1B4E9E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>0,3,0,0</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                                      Opacity="0.10" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="TxtWelcome"
                               Text="مرحباً بك في النظام"
                               Foreground="#F7941D" FontSize="17" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtUserInfo"
                               Foreground="#475569" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtLicenseInfo"
                               Foreground="#94A3B8" FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- معلومات التواصل - كما في الصورة -->
            <Border CornerRadius="8" Padding="20,12" HorizontalAlignment="Center"
                    Background="#1E293B">
                <StackPanel>
                    <TextBlock Text="التواصل مع اتقان سوفت"
                               Foreground="White" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="📞 " Foreground="#F7941D" FontSize="12"/>
                        <TextBlock Text="777(4b3b7."
                                   Foreground="#94A3B8" FontSize="12"
                                   FlowDirection="LeftToRight"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
                        <TextBlock Text="✉ " Foreground="#F7941D" FontSize="11"/>
                        <TextBlock Text="info@itqansoft.com"
                                   Foreground="#64748B" FontSize="11"
                                   FlowDirection="LeftToRight"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- الوقت والتاريخ في الأسفل -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                Background="Transparent" Padding="0,0,0,12">
            <TextBlock x:Name="TxtDateTime" Foreground="#94A3B8" FontSize="11"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Page>
