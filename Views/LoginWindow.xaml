<Window x:Class="RestaurantMS.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestaurantMS — itQAN Soft" Height="620" Width="460"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#8b949e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#f85149"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="Background"      Value="#21262d"/>
            <Setter Property="BorderBrush"     Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Height"          Value="48"/>
        </Style>
    </Window.Resources>

    <Border Background="#0d1117" CornerRadius="16" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.7" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- شريط النافذة -->
            <Grid Grid.Row="0" Margin="12,6" MouseLeftButtonDown="TitleBar_MouseDown">
                <Button Style="{StaticResource WinBtn}" Content="✕"
                        HorizontalAlignment="Left" Click="BtnClose_Click"/>
                <TextBlock Text="itQAN Soft — نظام إدارة المطاعم"
                           Foreground="#30363d" FontSize="11"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- محتوى تسجيل الدخول -->
            <StackPanel Grid.Row="1" Margin="44,0,44,36" VerticalAlignment="Center">

                <!-- شعار itQAN Soft -->
                <Border HorizontalAlignment="Center" Margin="0,0,0,6">
                    <Image Source="pack://application:,,,/Assets/itqansoft_logo.png"
                           Width="130" Height="130"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- اسم النظام -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock Text="نظام إدارة المطاعم"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Restaurant" Foreground="#F7941D" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="MS" Foreground="#1B4E9E" FontSize="13" FontWeight="Bold"/>
                        <TextBlock Text=" — إصدار 1.0" Foreground="#30363d" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- فاصل -->
                <Border Height="1" Background="#21262d" Margin="0,16,0,24"/>

                <!-- اسم المستخدم -->
                <TextBlock Text="اسم المستخدم" Foreground="#8b949e" FontSize="12"
                           Margin="0,0,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}" x:Name="UserFieldBorder">
                    <Grid Margin="14,0">
                        <TextBlock x:Name="UserPlaceholder" Text="أدخل اسم المستخدم"
                                   Foreground="#30363d" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox x:Name="TxtUsername" Background="Transparent"
                                 Foreground="White" BorderThickness="0"
                                 FontSize="14" VerticalAlignment="Center"
                                 CaretBrush="White"
                                 GotFocus="TxtUsername_GotFocus"
                                 LostFocus="TxtUsername_LostFocus"
                                 TextChanged="TxtUsername_TextChanged"
                                 KeyDown="Input_KeyDown"/>
                    </Grid>
                </Border>

                <!-- كلمة المرور -->
                <TextBlock Text="كلمة المرور" Foreground="#8b949e" FontSize="12"
                           Margin="0,16,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}" x:Name="PassFieldBorder">
                    <Grid Margin="14,0">
                        <TextBlock x:Name="PassPlaceholder" Text="أدخل كلمة المرور"
                                   Foreground="#30363d" VerticalAlignment="Center" FontSize="13"/>
                        <PasswordBox x:Name="TxtPassword" Background="Transparent"
                                     Foreground="White" BorderThickness="0"
                                     FontSize="14" VerticalAlignment="Center"
                                     CaretBrush="White"
                                     GotFocus="TxtPassword_GotFocus"
                                     LostFocus="TxtPassword_LostFocus"
                                     PasswordChanged="TxtPassword_Changed"
                                     KeyDown="Input_KeyDown"/>
                    </Grid>
                </Border>

                <!-- رسالة خطأ -->
                <Border x:Name="ErrorPanel" Background="#160c0c"
                        BorderBrush="#f85149" BorderThickness="1"
                        CornerRadius="8" Padding="12,10"
                        Margin="0,12,0,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " Foreground="#f85149" FontSize="14"/>
                        <TextBlock x:Name="LblError" Foreground="#ffa198"
                                   TextWrapping="Wrap" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- زر الدخول -->
                <Button x:Name="BtnLogin" Height="48" Margin="0,18,0,0"
                        Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1B4E9E" Offset="0"/>
                                        <GradientStop Color="#F7941D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtLoginLabel" Text="تسجيل الدخول"
                                   Foreground="White" FontSize="15" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  ←" Foreground="White" FontSize="15"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- بيانات الاختبار -->
                <Border Background="#0d1117" BorderBrush="#21262d" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="بيانات الدخول الافتراضية" Foreground="#30363d"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="admin" Foreground="#F7941D" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Text=" / " Foreground="#30363d" FontSize="12"/>
                            <TextBlock Text="admin123" Foreground="#1B4E9E" FontWeight="Bold" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- حقوق الملكية -->
                <TextBlock Text="© 2025 itQAN Soft — جميع الحقوق محفوظة"
                           Foreground="#21262d" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
