<Window x:Class="RestaurantMS.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestaurantMS — itQAN Soft" Height="640" Width="480"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource MutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Height"          Value="50"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.15" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- شريط النافذة -->
            <Grid Grid.Row="0" Margin="12,6" MouseLeftButtonDown="TitleBar_MouseDown"
                  Background="#F8FAFC">
                <Button Style="{StaticResource WinBtn}" Content="✕"
                        HorizontalAlignment="Left" Click="BtnClose_Click"/>
                <TextBlock Text="itQAN Soft — نظام إدارة المطاعم"
                           Foreground="{StaticResource MutedBrush}" FontSize="11"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- محتوى تسجيل الدخول -->
            <StackPanel Grid.Row="1" Margin="44,0,44,36" VerticalAlignment="Center">

                <!-- شعار -->
                <Border HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Image Source="pack://application:,,,/Assets/itqansoft_logo.png"
                           Width="110" Height="110"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- اسم النظام -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock Text="نظام إدارة المطاعم"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Restaurant" Foreground="{StaticResource AccentBrush}"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="MS" Foreground="{StaticResource BlueBrush}"
                                   FontSize="13" FontWeight="Bold"/>
                        <TextBlock Text=" — إصدار 1.0" Foreground="{StaticResource MutedBrush}"
                                   FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- فاصل -->
                <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,16,0,24"/>

                <!-- اسم المستخدم -->
                <TextBlock Text="اسم المستخدم" Foreground="{StaticResource MutedBrush}" FontSize="12"
                           Margin="0,0,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}" x:Name="UserFieldBorder">
                    <Grid Margin="14,0">
                        <TextBlock x:Name="UserPlaceholder" Text="أدخل اسم المستخدم"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center" FontSize="13"/>
                        <TextBox x:Name="TxtUsername" Background="Transparent"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderThickness="0" FontSize="14" VerticalAlignment="Center"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 GotFocus="TxtUsername_GotFocus"
                                 LostFocus="TxtUsername_LostFocus"
                                 TextChanged="TxtUsername_TextChanged"
                                 KeyDown="Input_KeyDown"/>
                    </Grid>
                </Border>

                <!-- كلمة المرور -->
                <TextBlock Text="كلمة المرور" Foreground="{StaticResource MutedBrush}" FontSize="12"
                           Margin="0,16,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}" x:Name="PassFieldBorder">
                    <Grid Margin="14,0">
                        <TextBlock x:Name="PassPlaceholder" Text="أدخل كلمة المرور"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center" FontSize="13"/>
                        <PasswordBox x:Name="TxtPassword" Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderThickness="0" FontSize="14" VerticalAlignment="Center"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     GotFocus="TxtPassword_GotFocus"
                                     LostFocus="TxtPassword_LostFocus"
                                     PasswordChanged="TxtPassword_Changed"
                                     KeyDown="Input_KeyDown"/>
                    </Grid>
                </Border>

                <!-- رسالة خطأ -->
                <Border x:Name="ErrorPanel" Background="#FEF2F2"
                        BorderBrush="#FECACA" BorderThickness="1"
                        CornerRadius="8" Padding="12,10"
                        Margin="0,12,0,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " Foreground="{StaticResource DangerBrush}" FontSize="14"/>
                        <TextBlock x:Name="LblError" Foreground="#B91C1C"
                                   TextWrapping="Wrap" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- زر الدخول -->
                <Button x:Name="BtnLogin" Height="50" Margin="0,18,0,0"
                        Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1B4E9E" Offset="0"/>
                                        <GradientStop Color="#F7941D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtLoginLabel" Text="تسجيل الدخول"
                                   Foreground="White" FontSize="15" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  ←" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- رابط بوابة المالك -->
                <Button Content="⚙  بوابة مالك النظام"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource MutedBrush}" FontSize="11"
                        Cursor="Hand" Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        Click="BtnOwnerPortal_Click"/>

                <!-- حقوق الملكية -->
                <TextBlock Text="© 2025 itQAN Soft — جميع الحقوق محفوظة"
                           Foreground="{StaticResource MutedBrush}" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
