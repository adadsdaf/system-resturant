<Window x:Class="RestaurantMS.Desktop.Views.Admin.PrinterSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إعدادات الطابعات"
        Width="620" Height="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        FlowDirection="RightToLeft"
        Background="Transparent">
    <Border Background="White" CornerRadius="12" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.14" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- شريط العنوان -->
            <Border Grid.Row="0" Background="#1B4E9E" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="🖨  إعدادات الطابعات" Foreground="White"
                               VerticalAlignment="Center" Margin="16,0" FontSize="15" FontWeight="SemiBold"/>
                    <Button Content="✕" HorizontalAlignment="Left" VerticalAlignment="Center"
                            Margin="12,0" Width="30" Height="30"
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- المحتوى -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel>

                    <!-- الطابعة الحرارية 80mm -->
                    <Border Background="#FFF7ED" BorderBrush="#F7941D" BorderThickness="1"
                            CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="🖨  الطابعة الحرارية — 80mm (Pixellon وما شابهها)"
                                       FontSize="14" FontWeight="Bold" Foreground="#92400E" Margin="0,0,0,12"/>

                            <TextBlock Text="اسم الطابعة في Windows" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtThermalName" Height="36"
                                     ToolTip="اسم الطابعة كما يظهر في إعدادات Windows — مثال: EPSON TM-T88V"
                                     Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>

                            <TextBlock Text="نوع الاتصال" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CmbThermalType" Height="36" Margin="0,0,0,10"
                                      SelectionChanged="CmbThermalType_SelectionChanged">
                                <ComboBoxItem Content="Windows (تحديد من قائمة الطابعات)" Tag="Windows" IsSelected="True"/>
                                <ComboBoxItem Content="شبكة (IP/Network)" Tag="Network"/>
                                <ComboBoxItem Content="منفذ تسلسلي (COM)" Tag="Serial"/>
                            </ComboBox>

                            <StackPanel x:Name="PanelThermalNetwork" Visibility="Collapsed">
                                <TextBlock Text="عنوان IP الطابعة" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtThermalAddress" Height="36"
                                         ToolTip="مثال: 192.168.1.100"
                                         Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>
                                <TextBlock Text="المنفذ (Port)" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtThermalPort" Height="36" Text="9100"
                                         Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>
                            </StackPanel>

                            <Button x:Name="BtnTestThermal" Content="🖨  اختبار الطباعة"
                                    Style="{StaticResource GhostButton}" Width="160"
                                    HorizontalAlignment="Right" Click="BtnTestThermal_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- طابعة A4 الكبيرة -->
                    <Border Background="#EFF6FF" BorderBrush="#1B4E9E" BorderThickness="1"
                            CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="🖨  طابعة A4 الكبيرة (الفواتير والتقارير)"
                                       FontSize="14" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,0,12"/>

                            <TextBlock Text="اسم الطابعة في Windows" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtLargeName" Height="36"
                                     ToolTip="اسم الطابعة كما يظهر في إعدادات Windows — مثال: HP LaserJet Pro"
                                     Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>

                            <TextBlock Text="نوع الاتصال" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CmbLargeType" Height="36" Margin="0,0,0,10"
                                      SelectionChanged="CmbLargeType_SelectionChanged">
                                <ComboBoxItem Content="Windows (تحديد من قائمة الطابعات)" Tag="Windows" IsSelected="True"/>
                                <ComboBoxItem Content="شبكة (IP/Network)" Tag="Network"/>
                                <ComboBoxItem Content="منفذ تسلسلي (COM)" Tag="Serial"/>
                            </ComboBox>

                            <StackPanel x:Name="PanelLargeNetwork" Visibility="Collapsed">
                                <TextBlock Text="عنوان IP الطابعة" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtLargeAddress" Height="36"
                                         ToolTip="مثال: 192.168.1.101"
                                         Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>
                                <TextBlock Text="المنفذ (Port)" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtLargePort" Height="36" Text="9100"
                                         Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>
                            </StackPanel>

                            <Button x:Name="BtnTestLarge" Content="🖨  اختبار الطباعة"
                                    Style="{StaticResource GhostButton}" Width="160"
                                    HorizontalAlignment="Right" Click="BtnTestLarge_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- قائمة الطابعات المتاحة -->
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="8" Padding="12" Margin="0,0,0,4">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="📋  الطابعات المتوفرة على هذا الجهاز:"
                                           FontWeight="SemiBold" Foreground="#475569" FontSize="12"/>
                                <Button Content="تحديث" DockPanel.Dock="Left" Margin="0,0,0,0"
                                        Style="{StaticResource GhostButton}" FontSize="11" Width="70"
                                        Click="BtnRefreshPrinters_Click"/>
                            </DockPanel>
                            <ListBox x:Name="LstPrinters" MaxHeight="100" FontSize="12"
                                     Background="Transparent" BorderThickness="0"
                                     SelectionChanged="LstPrinters_SelectionChanged"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- أزرار الحفظ -->
            <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                    Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="16,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="💾  حفظ الإعدادات" Style="{StaticResource PrimaryButton}"
                            Width="160" Click="BtnSave_Click" Margin="0,0,10,0"/>
                    <Button Content="إلغاء" Style="{StaticResource GhostButton}"
                            Width="90" Click="BtnClose_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
