<Window x:Class="RestaurantMS.Desktop.Views.Admin.CurrencyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="عملة" Width="420" Height="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        FlowDirection="RightToLeft" Background="Transparent">
    <Border Background="White" CornerRadius="12" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.14" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1B4E9E" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock x:Name="TxtTitle" Text="💱  إضافة عملة" Foreground="White"
                               VerticalAlignment="Center" Margin="16,0" FontSize="14" FontWeight="SemiBold"/>
                    <Button Content="✕" HorizontalAlignment="Left" Margin="10,0"
                            Width="28" Height="28" Background="Transparent" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,16">
                <TextBlock Text="اسم العملة *" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtName" Height="36" Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="رمز العملة (مثال: SAR)" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtCode" Height="36" Style="{StaticResource DarkInput}"
                                 CharacterCasing="Upper" MaxLength="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="الرمز (مثال: ر.س)" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtSymbol" Height="36" Style="{StaticResource DarkInput}" MaxLength="5"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="سعر الصرف مقابل العملة الأساسية"
                           Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtRate" Height="36" Style="{StaticResource DarkInput}"
                         Text="1.000000" Margin="0,0,0,10"/>

                <CheckBox x:Name="ChkIsLocal" Content="هذه هي العملة المحلية (الأساسية)"
                          Foreground="#1B4E9E" FontWeight="SemiBold" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                    Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="💾  حفظ" Style="{StaticResource PrimaryButton}"
                            Width="110" Click="BtnSave_Click" Margin="0,0,8,0"/>
                    <Button Content="إلغاء" Style="{StaticResource GhostButton}"
                            Width="80" Click="BtnClose_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
