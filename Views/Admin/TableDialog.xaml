<Window x:Class="RestaurantMS.Desktop.Views.Admin.TableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft"
        Background="{StaticResource BgBrush}"
        Title="بيانات الطاولة" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="إضافة طاولة"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="رقم الطاولة" Foreground="{StaticResource MutedBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtNumber" Style="{StaticResource DarkInput}" Height="42"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="السعة (عدد الأشخاص)" Foreground="{StaticResource MutedBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtCapacity" Style="{StaticResource DarkInput}" Height="42" Text="4"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="الموقع (مثال: صالة، خارجي)" Foreground="{StaticResource MutedBrush}"
                       FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtLocation" Style="{StaticResource DarkInput}" Height="42"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
            <Button Content="حفظ" Style="{StaticResource PrimaryButton}"
                    Width="100" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="إلغاء" Style="{StaticResource GhostButton}"
                    Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
