<Window x:Class="RestaurantMS.Desktop.Views.Customers.CustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="{StaticResource BgBrush}"
        Title="بيانات العميل" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="إضافة عميل"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="الاسم الكامل" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtName" Style="{StaticResource DarkInput}" Height="42" Margin="0,0,0,12"/>
            <TextBlock Text="رقم الهاتف" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtPhone" Style="{StaticResource DarkInput}" Height="42" Margin="0,0,0,12"/>
            <TextBlock Text="البريد الإلكتروني (اختياري)" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtEmail" Style="{StaticResource DarkInput}" Height="42"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
            <Button Content="حفظ" Style="{StaticResource PrimaryButton}" Width="100" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="إلغاء" Style="{StaticResource GhostButton}" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
