<Page x:Class="RestaurantMS.Desktop.Views.Customers.CustomersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft" Background="#0d1117">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="＋  عميل جديد"  Style="{StaticResource PrimaryButton}" Click="BtnAdd_Click" Margin="0,0,8,0"/>
            <Border Background="#21262d" CornerRadius="8" Padding="10,0" Height="40">
                <Grid>
                    <TextBlock Text="🔍  بحث..." Foreground="#30363d" VerticalAlignment="Center"
                               x:Name="SearchPh" FontSize="13"/>
                    <TextBox x:Name="TxtSearch" Background="Transparent" Foreground="White"
                             BorderThickness="0" FontSize="13" Width="200"
                             VerticalAlignment="Center" CaretBrush="White"
                             TextChanged="TxtSearch_Changed"/>
                </Grid>
            </Border>
            <Button Content="🔄 تحديث" Style="{StaticResource GhostButton}" Click="BtnRefresh_Click" Margin="8,0,0,0"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="GridCustomers" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"             Binding="{Binding customer_id}" Width="60"/>
                <DataGridTextColumn Header="الاسم"        Binding="{Binding full_name}"   Width="*"/>
                <DataGridTextColumn Header="الهاتف"       Binding="{Binding phone}"       Width="120"/>
                <DataGridTextColumn Header="البريد"       Binding="{Binding email}"       Width="160"/>
                <DataGridTextColumn Header="نقاط الولاء"  Binding="{Binding points}"      Width="110"/>
                <DataGridTextColumn Header="إجمالي الإنفاق" Binding="{Binding spent_fmt}" Width="130"/>
                <DataGridTextColumn Header="الحالة"       Binding="{Binding status_txt}"  Width="90"/>
                <DataGridTemplateColumn Header="إجراءات" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="تعديل" Tag="{Binding}" Style="{StaticResource GhostButton}"
                                        FontSize="12" Margin="0,0,6,0" Click="BtnEdit_Click"/>
                                <Button Content="تفعيل/إيقاف" Tag="{Binding customer_id}"
                                        Style="{StaticResource GhostButton}" FontSize="12"
                                        Click="BtnToggle_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
