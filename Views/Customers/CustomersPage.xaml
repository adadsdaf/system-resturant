<Page x:Class="RestaurantMS.Desktop.Views.Customers.CustomersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft"
      Background="{StaticResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="＋  عميل جديد"  Style="{StaticResource PrimaryButton}" Click="BtnAdd_Click" Margin="0,0,8,0"/>
            <Border Background="White" CornerRadius="8" Padding="10,0" Height="40"
                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                <Grid>
                    <TextBlock Text="🔍  بحث..." Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center" x:Name="SearchPh" FontSize="13"/>
                    <TextBox x:Name="TxtSearch" Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0" FontSize="13" Width="200"
                             VerticalAlignment="Center" CaretBrush="{StaticResource AccentBrush}"
                             TextChanged="TxtSearch_Changed"/>
                </Grid>
            </Border>
            <Button Content="🔄 تحديث" Style="{StaticResource GhostButton}" Click="BtnRefresh_Click" Margin="8,0,0,0"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="GridCustomers" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"             Binding="{Binding customer_id}" Width="60"/>
                <DataGridTextColumn Header="الاسم"        Binding="{Binding full_name}"   Width="*"/>
                <DataGridTextColumn Header="الهاتف"       Binding="{Binding phone}"       Width="120"/>
                <DataGridTextColumn Header="البريد"       Binding="{Binding email}"       Width="160"/>
                <DataGridTextColumn Header="نقاط الولاء"  Binding="{Binding points}"      Width="110"/>
                <DataGridTextColumn Header="إجمالي الزيارات" Binding="{Binding total_visits}" Width="120"/>
                <DataGridTemplateColumn Header="إجراءات" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="تعديل" Tag="{Binding}" Style="{StaticResource GhostButton}"
                                        Height="28" FontSize="12" Margin="2" Click="BtnEdit_Click"/>
                                <Button Content="تفعيل/إيقاف" Tag="{Binding customer_id}" Style="{StaticResource GhostButton}"
                                        Height="28" FontSize="12" Margin="2" Click="BtnToggle_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
