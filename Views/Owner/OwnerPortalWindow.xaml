<Window x:Class="RestaurantMS.Desktop.Views.Owner.OwnerPortalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بوابة مالك النظام — itQAN Soft"
        Height="700" Width="1100"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        MinWidth="900" MinHeight="580">

    <Window.Resources>
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#f85149"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OwnerNavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Margin"          Value="0,1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#243447"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OwnerNavBtnActive" TargetType="Button" BasedOn="{StaticResource OwnerNavBtn}">
            <Setter Property="Background" Value="#1c3a5e"/>
            <Setter Property="Foreground" Value="#F7941D"/>
        </Style>

        <Style x:Key="SetupInput" TargetType="TextBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#1E293B"/>
            <Setter Property="BorderBrush"     Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="CaretBrush"      Value="#1B4E9E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1B4E9E"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.15" Color="#1B4E9E"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}" CornerRadius="14" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.2" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <!-- ======= شاشة الإعداد الأولي ======= -->
            <Grid x:Name="PanelFirstRun" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- جانب أيمن — عرض ترويجي -->
                <Border Grid.Column="0" CornerRadius="14,0,0,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.5,1">
                            <GradientStop Color="#0F172A" Offset="0"/>
                            <GradientStop Color="#1B4E9E" Offset="0.6"/>
                            <GradientStop Color="#F7941D" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel VerticalAlignment="Center" Margin="40,0">
                        <Image Source="pack://application:,,,/Assets/itqansoft_logo.png"
                               Width="100" Height="100" HorizontalAlignment="Center" Margin="0,0,0,24"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="مرحباً بك في" Foreground="#CBD5E1" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="بوابة مالك النظام" Foreground="White" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <Border Height="1" Background="#ffffff22" Margin="0,20,0,20"/>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="✅  إنشاء تراخيص للمطاعم" Foreground="#CBD5E1" FontSize="13" Margin="0,0,0,8"/>
                            <TextBlock Text="✅  التحكم في الصلاحيات والأجهزة" Foreground="#CBD5E1" FontSize="13" Margin="0,0,0,8"/>
                            <TextBlock Text="✅  إدارة حسابات المطاعم" Foreground="#CBD5E1" FontSize="13" Margin="0,0,0,8"/>
                            <TextBlock Text="✅  متابعة الاشتراكات والتجديد" Foreground="#CBD5E1" FontSize="13"/>
                        </StackPanel>
                        <Border Height="1" Background="#ffffff22" Margin="0,20,0,20"/>
                        <TextBlock Text="© 2025 itQAN Soft" Foreground="#64748B" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- جانب أيسر — نموذج الإعداد -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="12,6" MouseLeftButtonDown="TitleBar_MouseDown">
                        <Button Style="{StaticResource WinBtn}" Content="✕"
                                HorizontalAlignment="Left" Click="BtnClose_Click"
                                Foreground="#9CA3AF"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="50,20,50,40" VerticalAlignment="Center">
                            <TextBlock Text="إعداد حساب مالك النظام"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="هذه الخطوة تتم مرة واحدة فقط عند أول تشغيل"
                                       Foreground="{StaticResource MutedBrush}" FontSize="13"
                                       Margin="0,0,0,28"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="اسم مالك النظام *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSetupOwnerName" Style="{StaticResource SetupInput}" Height="46"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="اسم برنامج / الشركة" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSetupSoftware" Style="{StaticResource SetupInput}" Height="46" Text="itQAN Soft"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="البريد الإلكتروني" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSetupEmail" Style="{StaticResource SetupInput}" Height="46"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="رقم الجوال" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSetupPhone" Style="{StaticResource SetupInput}" Height="46"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="كلمة المرور *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtSetupPassword" Height="46"
                                                 Background="White" Foreground="#1E293B"
                                                 BorderBrush="#D1D5DB" BorderThickness="1"
                                                 Padding="12,10" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="تأكيد كلمة المرور *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtSetupConfirm" Height="46"
                                                 Background="White" Foreground="#1E293B"
                                                 BorderBrush="#D1D5DB" BorderThickness="1"
                                                 Padding="12,10" FontSize="14"/>
                                </StackPanel>
                            </Grid>

                            <Border x:Name="SetupErrorPanel" Background="#FEF2F2"
                                    BorderBrush="#FECACA" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10"
                                    Margin="0,6,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="SetupErrorTxt" Foreground="#DC2626"
                                           FontSize="13" TextWrapping="Wrap"/>
                            </Border>

                            <Button x:Name="BtnSetupSave" Height="50" Margin="0,20,0,0"
                                    Cursor="Hand" Click="BtnSetupSave_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#1B4E9E" Offset="0"/>
                                                    <GradientStop Color="#F7941D" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock x:Name="TxtSetupBtnLabel" Text="إنشاء الحساب والمتابعة ←"
                                           Foreground="White" FontSize="15" FontWeight="Bold"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ======= لوحة تسجيل الدخول للمالك ======= -->
            <Grid x:Name="PanelLogin" Visibility="Collapsed">
                <Border Width="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="White" CornerRadius="16" Padding="40">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.12" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel>
                        <Image Source="pack://application:,,,/Assets/itqansoft_logo.png"
                               Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock x:Name="TxtLoginOwnerName" Text="بوابة المالك"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="أدخل كلمة المرور للدخول"
                                   Foreground="{StaticResource MutedBrush}" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,0,0,24"/>

                        <TextBlock Text="كلمة المرور" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="TxtLoginPassword" Height="48"
                                     Background="{StaticResource SurfaceBrush}" Foreground="#1E293B"
                                     BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                     Padding="14,10" FontSize="14"/>

                        <Border x:Name="LoginErrorPanel" Background="#FEF2F2"
                                BorderBrush="#FECACA" BorderThickness="1"
                                CornerRadius="8" Padding="12,10"
                                Margin="0,10,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="LoginErrorTxt" Foreground="#DC2626" FontSize="13"/>
                        </Border>

                        <Button x:Name="BtnOwnerLogin" Content="دخول البوابة  ←"
                                Height="48" Margin="0,16,0,0"
                                Style="{StaticResource BlueButton}" FontSize="14"
                                Click="BtnOwnerLogin_Click"/>

                        <Button Content="العودة للواجهة الرئيسية"
                                Style="{StaticResource GhostButton}" Height="40" Margin="0,10,0,0"
                                Click="BtnBackToLogin_Click"/>
                    </StackPanel>
                </Border>
                <Button Style="{StaticResource WinBtn}" Content="✕"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="20,20,0,0" Foreground="#9CA3AF"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- ======= لوحة التحكم الرئيسية للمالك ======= -->
            <Grid x:Name="PanelPortal" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- الشريط الجانبي -->
                <Border Grid.Column="0" CornerRadius="14,0,0,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0F172A" Offset="0"/>
                            <GradientStop Color="#1A2332" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,20,0,0">
                            <Image Source="pack://application:,,,/Assets/itqansoft_logo.png"
                                   Width="70" Height="70" HorizontalAlignment="Center" Margin="0,0,0,8"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock x:Name="TxtSidebarOwnerName" Text="itQAN Soft"
                                       Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="بوابة مالك النظام"
                                       Foreground="#64748B" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <Border Height="1" Margin="16,14,16,8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F7941D" Offset="0"/>
                                        <GradientStop Color="#1B4E9E" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10,0">
                            <StackPanel x:Name="OwnerNavPanel">
                                <TextBlock Text="لوحة التحكم" Foreground="#475569"
                                           FontSize="10" Margin="14,6,14,3" FontWeight="SemiBold"/>
                                <Button Tag="Overview" Click="OwnerNav_Click" Style="{StaticResource OwnerNavBtnActive}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="14" Width="22"/>
                                        <TextBlock Text="نظرة عامة" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="التراخيص" Foreground="#475569"
                                           FontSize="10" Margin="14,10,14,3" FontWeight="SemiBold"/>
                                <Button Tag="NewLicense" Click="OwnerNav_Click" Style="{StaticResource OwnerNavBtn}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔑" FontSize="14" Width="22"/>
                                        <TextBlock Text="إنشاء ترخيص جديد" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Tag="Licenses" Click="OwnerNav_Click" Style="{StaticResource OwnerNavBtn}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" FontSize="14" Width="22"/>
                                        <TextBlock Text="التراخيص المُنشأة" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="النظام" Foreground="#475569"
                                           FontSize="10" Margin="14,10,14,3" FontWeight="SemiBold"/>
                                <Button Tag="RestaurantSetup" Click="OwnerNav_Click" Style="{StaticResource OwnerNavBtn}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏪" FontSize="14" Width="22"/>
                                        <TextBlock Text="إعداد المطعم" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Tag="OwnerSettings" Click="OwnerNav_Click" Style="{StaticResource OwnerNavBtn}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙️" FontSize="14" Width="22"/>
                                        <TextBlock Text="إعدادات المالك" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2" Margin="10,0,10,14">
                            <Button Content="⏏  الخروج للنظام" Style="{StaticResource OwnerNavBtn}"
                                    Click="BtnExitPortal_Click" Foreground="#F7941D"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- المنطقة الرئيسية -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- شريط العنوان -->
                    <Border Grid.Row="0" Background="{StaticResource BgBrush}"
                            MouseLeftButtonDown="TitleBar_MouseDown">
                        <Grid Margin="20,0">
                            <TextBlock x:Name="TxtPortalPageTitle"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="Bold"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Button Width="30" Height="30" Content="─"
                                        Background="Transparent" Foreground="{StaticResource MutedBrush}"
                                        BorderThickness="0" Cursor="Hand" FontSize="16"
                                        Click="BtnMinimize_Click"/>
                                <Button Width="30" Height="30" Content="□"
                                        Background="Transparent" Foreground="{StaticResource MutedBrush}"
                                        BorderThickness="0" Cursor="Hand" FontSize="14"
                                        Click="BtnMaximize_Click"/>
                                <Button Width="30" Height="30" Content="✕"
                                        Background="Transparent" Foreground="{StaticResource MutedBrush}"
                                        BorderThickness="0" Cursor="Hand" FontSize="14"
                                        Click="BtnClose_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- محتوى الصفحة -->
                    <ScrollViewer Grid.Row="1" x:Name="PortalScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource BgBrush}">
                        <Grid x:Name="PortalContent" Margin="24">

                            <!-- ===== نظرة عامة ===== -->
                            <StackPanel x:Name="PanelOverview" Visibility="Visible">
                                <Grid Margin="0,0,0,24">
                                    <StackPanel>
                                        <TextBlock Text="مرحباً في بوابة مالك النظام 👋"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="20" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtOverviewDate"
                                                   Foreground="{StaticResource MutedBrush}" FontSize="13"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <UniformGrid Columns="3" Margin="0,0,0,20">
                                    <Border Margin="0,0,8,0" CornerRadius="12" Padding="20">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1B4E9E" Offset="0"/>
                                                <GradientStop Color="#0d3070" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock Text="🔑" FontSize="28" Margin="0,0,0,8"/>
                                            <TextBlock x:Name="TxtTotalLicenses" Text="0"
                                                       Foreground="White" FontSize="28" FontWeight="Bold"/>
                                            <TextBlock Text="ترخيص منشأ" Foreground="#ffffff88" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="4,0" CornerRadius="12" Padding="20">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F7941D" Offset="0"/>
                                                <GradientStop Color="#c4700a" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock Text="🏪" FontSize="28" Margin="0,0,0,8"/>
                                            <TextBlock x:Name="TxtActiveLicenses" Text="0"
                                                       Foreground="White" FontSize="28" FontWeight="Bold"/>
                                            <TextBlock Text="ترخيص نشط" Foreground="#ffffff88" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="8,0,0,0" CornerRadius="12" Padding="20">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#16A34A" Offset="0"/>
                                                <GradientStop Color="#0d6432" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel>
                                            <TextBlock Text="📅" FontSize="28" Margin="0,0,0,8"/>
                                            <TextBlock x:Name="TxtExpiringSoon" Text="0"
                                                       Foreground="White" FontSize="28" FontWeight="Bold"/>
                                            <TextBlock Text="تنتهي قريباً (30 يوم)" Foreground="#ffffff88" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Background="White" CornerRadius="12" Padding="20"
                                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="معلومات مالك النظام"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="15" FontWeight="Bold" Margin="0,0,0,16"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock x:Name="TxtOwnerInfoName" FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                                                <TextBlock x:Name="TxtOwnerInfoEmail" FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="TxtOwnerInfoPhone" FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                                                <TextBlock x:Name="TxtOwnerInfoSoftware" FontSize="13"
                                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ===== إنشاء ترخيص جديد ===== -->
                            <Border x:Name="PanelNewLicense" Visibility="Collapsed"
                                    Background="White" CornerRadius="12" Padding="28"
                                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="إنشاء ترخيص جديد للمطعم 🔑"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18" FontWeight="Bold" Margin="0,0,0,24"/>

                                        <!-- بيانات العميل -->
                                        <TextBlock Text="بيانات المطعم / العميل"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,12"
                                                   TextDecorations="Underline"/>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="اسم المطعم *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtLicRestName" Style="{StaticResource DarkInput}" Height="40"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="اسم صاحب المطعم *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtLicCustName" Style="{StaticResource DarkInput}" Height="40"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="الجوال" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtLicPhone" Style="{StaticResource DarkInput}" Height="40"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="البريد الإلكتروني" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtLicEmail" Style="{StaticResource DarkInput}" Height="40"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- إعدادات الترخيص -->
                                        <TextBlock Text="إعدادات الترخيص"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12" FontWeight="Bold" Margin="0,10,0,12"
                                                   TextDecorations="Underline"/>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="تاريخ الانتهاء *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtLicExpiry" Style="{StaticResource DarkInput}" Height="40"
                                                         Text="" ToolTip="مثال: 2026-12-31"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="الإصدار" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="CmbLicEdition" Style="{StaticResource DarkCombo}" Height="40">
                                                    <ComboBoxItem Content="Full" IsSelected="True"/>
                                                    <ComboBoxItem Content="Basic"/>
                                                    <ComboBoxItem Content="POS Only"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="بصمة الجهاز (اختياري)" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtLicDevice" Style="{StaticResource DarkInput}" Height="40"
                                                         ToolTip="اتركه فارغاً لإنشاء ترخيص غير مقيّد بجهاز"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- عدد الأجهزة -->
                                        <TextBlock Text="عدد الأجهزة المسموح بها"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12" FontWeight="Bold" Margin="0,10,0,12"
                                                   TextDecorations="Underline"/>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="نقاط البيع" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtMaxPos" Style="{StaticResource DarkInput}" Height="40" Text="1"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="المطبخ" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtMaxKitchen" Style="{StaticResource DarkInput}" Height="40" Text="1"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="الكاشير" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtMaxCashier" Style="{StaticResource DarkInput}" Height="40" Text="2"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="6">
                                                <TextBlock Text="إجمالي الأجهزة" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                <TextBox x:Name="TxtMaxTotal" Style="{StaticResource DarkInput}" Height="40" Text="5"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- الصلاحيات -->
                                        <TextBlock Text="الوحدات المسموح بها"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12" FontWeight="Bold" Margin="0,10,0,12"
                                                   TextDecorations="Underline"/>
                                        <UniformGrid Columns="5" Margin="0,0,0,20">
                                            <CheckBox x:Name="ChkPOS"          Content="نقطة البيع"    IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                            <CheckBox x:Name="ChkKitchen"      Content="المطبخ"        IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                            <CheckBox x:Name="ChkInventory"    Content="المخزون"       IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                            <CheckBox x:Name="ChkCustomers"    Content="العملاء"       IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                            <CheckBox x:Name="ChkSuppliers"    Content="الموردون"      IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                            <CheckBox x:Name="ChkSales"        Content="المبيعات"      IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                            <CheckBox x:Name="ChkReservations" Content="الحجوزات"      IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                            <CheckBox x:Name="ChkReports"      Content="التقارير"      IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                            <CheckBox x:Name="ChkAdmin"        Content="الإدارة"       IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                            <CheckBox x:Name="ChkMenu"         Content="القائمة"       IsChecked="True" Margin="0,0,12,10" FontSize="13"/>
                                        </UniformGrid>

                                        <Border x:Name="LicErrorPanel" Background="#FEF2F2"
                                                BorderBrush="#FECACA" BorderThickness="1"
                                                CornerRadius="8" Padding="12,10"
                                                Margin="0,0,0,16" Visibility="Collapsed">
                                            <TextBlock x:Name="LicErrorTxt" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap"/>
                                        </Border>

                                        <Button Content="🔑  إنشاء مفتاح الترخيص"
                                                Style="{StaticResource PrimaryButton}"
                                                Height="48" FontSize="14"
                                                Click="BtnGenerateLicense_Click"/>

                                        <!-- نتيجة المفتاح -->
                                        <Border x:Name="LicResultPanel" Visibility="Collapsed"
                                                Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1"
                                                CornerRadius="10" Padding="16" Margin="0,20,0,0">
                                            <StackPanel>
                                                <TextBlock Text="✅ تم إنشاء مفتاح الترخيص بنجاح!"
                                                           Foreground="#16A34A" FontSize="14" FontWeight="Bold"
                                                           Margin="0,0,0,10"/>
                                                <TextBlock Text="مفتاح الترخيص:" Foreground="#15803D" FontSize="12" Margin="0,0,0,6"/>
                                                <Border Background="White" BorderBrush="#BBF7D0" BorderThickness="1"
                                                        CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
                                                    <TextBox x:Name="TxtGeneratedKey" Background="Transparent"
                                                             BorderThickness="0" FontSize="11"
                                                             Foreground="#1E293B" IsReadOnly="True"
                                                             TextWrapping="Wrap" FontFamily="Consolas"/>
                                                </Border>
                                                <Button Content="📋  نسخ المفتاح"
                                                        Style="{StaticResource GhostButton}"
                                                        HorizontalAlignment="Right"
                                                        Click="BtnCopyKey_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- ===== قائمة التراخيص ===== -->
                            <Border x:Name="PanelLicenses" Visibility="Collapsed"
                                    Background="White" CornerRadius="12" Padding="24"
                                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="التراخيص المُنشأة 📋"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                                    <DataGrid x:Name="GridLicenses" Style="{StaticResource DataGridStyle}"
                                              MaxHeight="500">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="اسم المطعم"    Binding="{Binding RestaurantName}" Width="*"/>
                                            <DataGridTextColumn Header="صاحب المطعم"   Binding="{Binding CustomerName}"   Width="140"/>
                                            <DataGridTextColumn Header="الإصدار"        Binding="{Binding Edition}"        Width="80"/>
                                            <DataGridTextColumn Header="الأجهزة"        Binding="{Binding MaxTotalDevices}" Width="70"/>
                                            <DataGridTextColumn Header="الانتهاء"       Binding="{Binding ExpiryDate}"     Width="110"/>
                                            <DataGridTextColumn Header="الحالة"         Binding="{Binding StatusTxt}"      Width="90"/>
                                            <DataGridTemplateColumn Header="المفتاح" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="نسخ" Tag="{Binding LicenseKey}"
                                                                Style="{StaticResource GhostButton}"
                                                                FontSize="11" Height="28"
                                                                Click="BtnCopyStoredKey_Click"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- ===== إعداد المطعم ===== -->
                            <Border x:Name="PanelRestaurantSetup" Visibility="Collapsed"
                                    Background="White" CornerRadius="12" Padding="28"
                                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                                </Border.Effect>
                                <StackPanel MaxWidth="500">
                                    <TextBlock Text="إعداد المطعم 🏪"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBlock Text="تهيئة النظام لمطعم جديد — إنشاء قاعدة البيانات والبيانات الأولية"
                                               Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,0,0,24"/>

                                    <TextBlock Text="اسم المطعم *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtRSRestName" Style="{StaticResource DarkInput}" Height="44" Margin="0,0,0,14"/>

                                    <TextBlock Text="اسم مدير المطعم *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtRSManagerName" Style="{StaticResource DarkInput}" Height="44" Margin="0,0,0,14"/>

                                    <TextBlock Text="اسم المستخدم للمدير *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtRSUsername" Style="{StaticResource DarkInput}" Height="44" Margin="0,0,0,14"/>

                                    <TextBlock Text="كلمة المرور *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtRSPassword" Height="44"
                                                 Background="{StaticResource SurfaceBrush}" Foreground="#1E293B"
                                                 BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                                 Padding="10,8" FontSize="14" Margin="0,0,0,14"/>

                                    <TextBlock Text="تأكيد كلمة المرور *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtRSConfirmPassword" Height="44"
                                                 Background="{StaticResource SurfaceBrush}" Foreground="#1E293B"
                                                 BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                                 Padding="10,8" FontSize="14" Margin="0,0,0,14"/>

                                    <Border x:Name="RSErrorPanel" Background="#FEF2F2"
                                            BorderBrush="#FECACA" BorderThickness="1"
                                            CornerRadius="8" Padding="12,10"
                                            Margin="0,0,0,16" Visibility="Collapsed">
                                        <TextBlock x:Name="RSErrorTxt" Foreground="#DC2626" FontSize="13" TextWrapping="Wrap"/>
                                    </Border>

                                    <Border x:Name="RSSuccessPanel" Background="#F0FDF4"
                                            BorderBrush="#BBF7D0" BorderThickness="1"
                                            CornerRadius="8" Padding="12,10"
                                            Margin="0,0,0,16" Visibility="Collapsed">
                                        <TextBlock x:Name="RSSuccessTxt" Foreground="#16A34A" FontSize="13" TextWrapping="Wrap"/>
                                    </Border>

                                    <Button x:Name="BtnSetupRestaurant" Content="🏪  تهيئة المطعم وإنشاء الحساب"
                                            Style="{StaticResource PrimaryButton}"
                                            Height="48" FontSize="14"
                                            Click="BtnSetupRestaurant_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- ===== إعدادات المالك ===== -->
                            <Border x:Name="PanelOwnerSettings" Visibility="Collapsed"
                                    Background="White" CornerRadius="12" Padding="28"
                                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                                </Border.Effect>
                                <StackPanel MaxWidth="480">
                                    <TextBlock Text="إعدادات مالك النظام ⚙️"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18" FontWeight="Bold" Margin="0,0,0,24"/>

                                    <TextBlock Text="اسم المالك" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSettOwnerName" Style="{StaticResource DarkInput}" Height="44" Margin="0,0,0,14"/>

                                    <TextBlock Text="اسم الشركة / البرنامج" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSettSoftware" Style="{StaticResource DarkInput}" Height="44" Margin="0,0,0,14"/>

                                    <TextBlock Text="البريد الإلكتروني" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSettEmail" Style="{StaticResource DarkInput}" Height="44" Margin="0,0,0,14"/>

                                    <TextBlock Text="رقم الجوال" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSettPhone" Style="{StaticResource DarkInput}" Height="44" Margin="0,0,0,20"/>

                                    <Button Content="💾  حفظ المعلومات" Style="{StaticResource PrimaryButton}"
                                            Height="44" Margin="0,0,0,24"
                                            Click="BtnSaveOwnerInfo_Click"/>

                                    <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,0,0,24"/>

                                    <TextBlock Text="تغيير كلمة المرور" Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                    <TextBlock Text="كلمة المرور الجديدة" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtNewPassword" Height="44"
                                                 Background="{StaticResource SurfaceBrush}" Foreground="#1E293B"
                                                 BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                                 Padding="10,8" FontSize="14" Margin="0,0,0,14"/>

                                    <TextBlock Text="تأكيد كلمة المرور" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtConfirmNewPassword" Height="44"
                                                 Background="{StaticResource SurfaceBrush}" Foreground="#1E293B"
                                                 BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                                 Padding="10,8" FontSize="14" Margin="0,0,0,14"/>

                                    <Button Content="🔒  تغيير كلمة المرور" Style="{StaticResource BlueButton}"
                                            Height="44" Click="BtnChangePassword_Click"/>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>
