<Page x:Class="RestaurantMS.Desktop.Views.Reservations.ReservationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft" Background="#0d1117">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="＋  حجز جديد"   Style="{StaticResource PrimaryButton}" Click="BtnAdd_Click"     Margin="0,0,8,0"/>
            <Button Content="🔄 تحديث"        Style="{StaticResource GhostButton}"   Click="BtnRefresh_Click" Margin="0,0,8,0"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="عرض يوم:" Foreground="#8b949e" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                <DatePicker x:Name="DpFilter" Width="130" Height="36"
                            SelectedDateChanged="DpFilter_Changed"/>
            </StackPanel>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="GridRes" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"           Binding="{Binding reservation_id}" Width="60"/>
                <DataGridTextColumn Header="العميل"      Binding="{Binding customer_name}"  Width="*"/>
                <DataGridTextColumn Header="الهاتف"      Binding="{Binding phone}"          Width="120"/>
                <DataGridTextColumn Header="التاريخ"     Binding="{Binding date_fmt}"       Width="110"/>
                <DataGridTextColumn Header="الوقت"       Binding="{Binding time_fmt}"       Width="90"/>
                <DataGridTextColumn Header="عدد الأشخاص" Binding="{Binding party_size}"    Width="100"/>
                <DataGridTextColumn Header="الطاولة"     Binding="{Binding table_num}"      Width="90"/>
                <DataGridTextColumn Header="الحالة"      Binding="{Binding status_txt}"     Width="110"/>
                <DataGridTemplateColumn Header="إجراءات" Width="190">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="تأكيد" Tag="{Binding reservation_id}"
                                        Style="{StaticResource GhostButton}" FontSize="12"
                                        Margin="0,0,4,0" Click="BtnConfirm_Click"/>
                                <Button Content="إلغاء"  Tag="{Binding reservation_id}"
                                        Style="{StaticResource DangerButton}" FontSize="12"
                                        Margin="0,0,4,0" Click="BtnCancel_Click"/>
                                <Button Content="لم يحضر" Tag="{Binding reservation_id}"
                                        Style="{StaticResource GhostButton}" FontSize="12"
                                        Click="BtnNoShow_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
