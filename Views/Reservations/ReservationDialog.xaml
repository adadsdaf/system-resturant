<Window x:Class="RestaurantMS.Desktop.Views.Reservations.ReservationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="#0d1117"
        Title="حجز جديد" Height="400" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="إضافة حجز جديد"
                   Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="اسم العميل" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtName" Style="{StaticResource DarkInput}" Height="40"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="رقم الهاتف" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtPhone" Style="{StaticResource DarkInput}" Height="40"/>
                </StackPanel>
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="التاريخ" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <DatePicker x:Name="DpDate" Height="40"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="الوقت (مثال 19:30)" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtTime" Style="{StaticResource DarkInput}" Height="40" Text="12:00"/>
                </StackPanel>
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="عدد الأشخاص" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtParty" Style="{StaticResource DarkInput}" Height="40" Text="2"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="الطاولة" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbTable" Style="{StaticResource DarkCombo}" Height="40"
                              DisplayMemberPath="Display" SelectedValuePath="table_id"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="ملاحظات خاصة" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNotes" Style="{StaticResource DarkInput}" Height="50" TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,16,0,0">
            <Button Content="حجز" Style="{StaticResource PrimaryButton}" Width="100" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="إلغاء" Style="{StaticResource GhostButton}" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
