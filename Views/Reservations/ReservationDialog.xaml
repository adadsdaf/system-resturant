<Window x:Class="RestaurantMS.Desktop.Views.Reservations.ReservationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="{StaticResource BgBrush}"
        Title="حجز جديد" Height="420" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="إضافة حجز جديد"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="اسم العميل" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtName" Style="{StaticResource DarkInput}" Height="42"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="رقم الهاتف" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtPhone" Style="{StaticResource DarkInput}" Height="42"/>
                </StackPanel>
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="التاريخ" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <DatePicker x:Name="DpDate" Height="42"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="الوقت (مثال 19:30)" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtTime" Style="{StaticResource DarkInput}" Height="42" Text="12:00"/>
                </StackPanel>
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="عدد الأشخاص" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtParty" Style="{StaticResource DarkInput}" Height="42" Text="2"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="الطاولة" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CmbTable" Style="{StaticResource DarkCombo}" Height="42"
                              DisplayMemberPath="Display" SelectedValuePath="table_id"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="ملاحظات خاصة" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtNotes" Style="{StaticResource DarkInput}" Height="50" TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,16,0,0">
            <Button Content="حجز" Style="{StaticResource PrimaryButton}" Width="100" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="إلغاء" Style="{StaticResource GhostButton}" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
