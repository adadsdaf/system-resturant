<Window x:Class="RestaurantMS.Desktop.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="الإعداد الأولي — itQAN Soft" Height="650" Width="480"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource MutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Height"          Value="48"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.15" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- شريط النافذة -->
            <Grid Grid.Row="0" Margin="12,6" MouseLeftButtonDown="TitleBar_MouseDown"
                  Background="{StaticResource SurfaceBrush}">
                <Button Style="{StaticResource WinBtn}" Content="✕"
                        HorizontalAlignment="Left" Click="BtnClose_Click"/>
                <TextBlock Text="itQAN Soft — الإعداد الأولي"
                           Foreground="{StaticResource MutedBrush}" FontSize="11"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- محتوى الإعداد -->
            <StackPanel Grid.Row="1" Margin="44,0,44,36" VerticalAlignment="Center">

                <!-- شعار -->
                <Border HorizontalAlignment="Center" Margin="0,0,0,6">
                    <Image Source="pack://application:,,,/Assets/itqansoft_logo.png"
                           Width="110" Height="110"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- عنوان -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock Text="مرحباً بك في النظام!"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="21" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="لا يوجد حساب مدير حتى الآن. أنشئ الأول الآن."
                               Foreground="{StaticResource MutedBrush}" FontSize="12"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- فاصل -->
                <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,16,0,20"/>

                <!-- اسم المطعم -->
                <TextBlock Text="اسم المطعم" Foreground="{StaticResource MutedBrush}"
                           FontSize="12" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,14">
                    <TextBox x:Name="TxtRestName" Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0" FontSize="14" Margin="14,0"
                             VerticalAlignment="Center"
                             CaretBrush="{StaticResource AccentBrush}"
                             KeyDown="Input_KeyDown"/>
                </Border>

                <!-- الاسم الكامل -->
                <TextBlock Text="الاسم الكامل" Foreground="{StaticResource MutedBrush}"
                           FontSize="12" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,14">
                    <TextBox x:Name="TxtFullName" Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0" FontSize="14" Margin="14,0"
                             VerticalAlignment="Center"
                             CaretBrush="{StaticResource AccentBrush}"
                             KeyDown="Input_KeyDown"/>
                </Border>

                <!-- اسم المستخدم -->
                <TextBlock Text="اسم المستخدم" Foreground="{StaticResource MutedBrush}"
                           FontSize="12" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,14">
                    <TextBox x:Name="TxtUsername" Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0" FontSize="14" Margin="14,0"
                             VerticalAlignment="Center"
                             CaretBrush="{StaticResource AccentBrush}"
                             KeyDown="Input_KeyDown"/>
                </Border>

                <!-- كلمة المرور -->
                <TextBlock Text="كلمة المرور" Foreground="{StaticResource MutedBrush}"
                           FontSize="12" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,14">
                    <PasswordBox x:Name="TxtPassword" Background="Transparent"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderThickness="0" FontSize="14" Margin="14,0"
                                 VerticalAlignment="Center"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 KeyDown="Input_KeyDown"/>
                </Border>

                <!-- تأكيد كلمة المرور -->
                <TextBlock Text="تأكيد كلمة المرور" Foreground="{StaticResource MutedBrush}"
                           FontSize="12" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,0">
                    <PasswordBox x:Name="TxtConfirmPassword" Background="Transparent"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderThickness="0" FontSize="14" Margin="14,0"
                                 VerticalAlignment="Center"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 KeyDown="Input_KeyDown"/>
                </Border>

                <!-- رسالة خطأ -->
                <Border x:Name="ErrorPanel" Background="#FEF2F2"
                        BorderBrush="#FECACA" BorderThickness="1"
                        CornerRadius="8" Padding="12,8"
                        Margin="0,10,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="LblError" Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap" FontSize="13"/>
                </Border>

                <!-- زر الإنشاء -->
                <Button x:Name="BtnCreateAdmin" Height="50" Margin="0,18,0,0"
                        Cursor="Hand" Click="BtnCreateAdmin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1B4E9E" Offset="0"/>
                                        <GradientStop Color="#F7941D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="TxtBtnLabel" Text="إنشاء حساب المدير"
                               Foreground="White" FontSize="15" FontWeight="Bold"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
