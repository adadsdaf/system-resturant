<Window x:Class="RestaurantMS.Desktop.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="الإعداد الأولي — itQAN Soft" Height="650" Width="480"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Height"          Value="48"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgColor}" CornerRadius="16" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="12" Opacity="0.7" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- شريط النافذة -->
            <Grid Grid.Row="0" Margin="12,6" MouseLeftButtonDown="TitleBar_MouseDown">
                <Button Style="{StaticResource WinBtn}" Content="✕"
                        HorizontalAlignment="Left" Click="BtnClose_Click"/>
                <TextBlock Text="itQAN Soft — الإعداد الأولي"
                           Foreground="{StaticResource TextPrimary}" FontSize="11"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- محتوى الإعداد -->
            <StackPanel Grid.Row="1" Margin="44,0,44,36" VerticalAlignment="Center">

                <!-- شعار -->
                <Border HorizontalAlignment="Center" Margin="0,0,0,6">
                    <Image Source="pack://application:,,,/Assets/itqansoft_logo.png"
                           Width="120" Height="120"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- عنوان -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock Text="مرحباً بك في النظام!" 
                               Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="يرجى إنشاء حساب المدير الأول للمتابعة"
                               Foreground="{StaticResource TextMuted}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                 <!-- فاصل -->
                <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,16,0,24"/>

                <!-- الاسم الكامل -->
                <TextBlock Text="الاسم الكامل" Foreground="{StaticResource TextMuted}" FontSize="12"
                           Margin="0,0,0,6" FontWeight="SemiBold"/>
                <Border Style="{StaticResource FieldBorder}">
                    <TextBox x:Name="TxtFullName" Background="Transparent"
                             Foreground="{StaticResource TextPrimary}" BorderThickness="0"
                             FontSize="14" VerticalAlignment="Center"
                              Padding="14,0" CaretBrush="{StaticResource AccentOrange}"/>
                 </Border>
             
                 <!-- اسم المستخدم -->
                 <TextBlock Text="اسم المستخدم (للتحكم)" Foreground="{StaticResource TextMuted}" FontSize="12"
                            Margin="0,16,0,6" FontWeight="SemiBold"/>
                 <Border Style="{StaticResource FieldBorder}">
                     <TextBox x:Name="TxtUsername" Background="Transparent"
                              Foreground="{StaticResource TextPrimary}" BorderThickness="0"
                              FontSize="14" VerticalAlignment="Center"
                              Padding="14,0" CaretBrush="{StaticResource AccentOrange}"/>
                 </Border>
             
                 <!-- اسم المطعم -->
                 <TextBlock Text="اسم المطعم" Foreground="{StaticResource TextMuted}" FontSize="12"
                            Margin="0,16,0,6" FontWeight="SemiBold"/>
                 <Border Style="{StaticResource FieldBorder}">
                     <TextBox x:Name="TxtRestName" Background="Transparent"
                              Foreground="{StaticResource TextPrimary}" BorderThickness="0"
                              FontSize="14" VerticalAlignment="Center"
                              Padding="14,0" CaretBrush="{StaticResource AccentOrange}"/>
                 </Border>
             
                 <!-- كلمة المرور -->
                 <TextBlock Text="كلمة المرور" Foreground="{StaticResource TextMuted}" FontSize="12"
                            Margin="0,16,0,6" FontWeight="SemiBold"/>
                 <Border Style="{StaticResource FieldBorder}">
                     <PasswordBox x:Name="TxtPassword" Background="Transparent"
                                  Foreground="{StaticResource TextPrimary}" BorderThickness="0"
                                  FontSize="14" VerticalAlignment="Center"
                                  Padding="14,0" CaretBrush="{StaticResource AccentOrange}"/>
                 </Border>
             
                 <!-- تأكيد كلمة المرور -->
                 <TextBlock Text="تأكيد كلمة المرور" Foreground="{StaticResource TextMuted}" FontSize="12"
                            Margin="0,16,0,6" FontWeight="SemiBold"/>
                 <Border Style="{StaticResource FieldBorder}">
                     <PasswordBox x:Name="TxtConfirmPassword" Background="Transparent"
                                  Foreground="{StaticResource TextPrimary}" BorderThickness="0"
                                  FontSize="14" VerticalAlignment="Center"
                                  Padding="14,0" CaretBrush="{StaticResource AccentOrange}"
                                  KeyDown="Input_KeyDown"/>
                </Border>

                <!-- رسالة خطأ -->
                <Border x:Name="ErrorPanel" Background="#fef2f2"
                        BorderBrush="#fecaca" BorderThickness="1"
                        CornerRadius="8" Padding="12,10"
                        Margin="0,12,0,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " Foreground="{StaticResource DangerBrush}" FontSize="14"/>
                        <TextBlock x:Name="LblError" Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- زر إنشاء المدير -->
                <Button x:Name="BtnCreateAdmin" Height="48" Margin="0,18,0,0"
                        Cursor="Hand" Click="BtnCreateAdmin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1B4E9E" Offset="0"/>
                                        <GradientStop Color="#F7941D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtBtnLabel" Text="إنشاء حساب المدير"
                                   Foreground="White" FontSize="15" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  ←" Foreground="White" FontSize="15"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- تذييل -->
                <TextBlock Text="© 2025 itQAN Soft — جميع الحقوق محفوظة"
                           Foreground="{StaticResource TextMuted}" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
