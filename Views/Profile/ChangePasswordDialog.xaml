<Window x:Class="RestaurantMS.Desktop.Views.Profile.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تغيير كلمة المرور"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="420" Height="460"
        ShowInTaskbar="False">

    <Border Background="White" CornerRadius="14" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.18" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- رأس النافذة -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" Padding="20,14" MouseLeftButtonDown="Header_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#1B4E9E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔑" FontSize="18" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="تغيير كلمة المرور" Foreground="White"
                                       FontSize="15" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtUserLabel" Foreground="#94A3B8"
                                       FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Left" VerticalAlignment="Center"
                            Width="28" Height="28" Content="✕"
                            Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnCancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#DC2626"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- المحتوى -->
            <StackPanel Grid.Row="1" Margin="28,20">

                <!-- الرسالة -->
                <TextBlock Text="أدخل كلمة المرور الحالية ثم كلمة المرور الجديدة"
                           Foreground="#64748B" FontSize="12" Margin="0,0,0,20"
                           TextWrapping="Wrap"/>

                <!-- كلمة المرور الحالية -->
                <TextBlock Text="كلمة المرور الحالية" Foreground="#374151"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border x:Name="CurrentPassBorder" Background="#F8FAFC"
                        BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8"
                        Height="44" Margin="0,0,0,14">
                    <PasswordBox x:Name="TxtCurrentPass" Background="Transparent"
                                 BorderThickness="0" Padding="12,0" FontSize="13"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="Pass_Changed"/>
                </Border>

                <!-- كلمة المرور الجديدة -->
                <TextBlock Text="كلمة المرور الجديدة" Foreground="#374151"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border x:Name="NewPassBorder" Background="#F8FAFC"
                        BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8"
                        Height="44" Margin="0,0,0,14">
                    <PasswordBox x:Name="TxtNewPass" Background="Transparent"
                                 BorderThickness="0" Padding="12,0" FontSize="13"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="Pass_Changed"/>
                </Border>

                <!-- تأكيد كلمة المرور -->
                <TextBlock Text="تأكيد كلمة المرور الجديدة" Foreground="#374151"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border x:Name="ConfirmPassBorder" Background="#F8FAFC"
                        BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8"
                        Height="44" Margin="0,0,0,18">
                    <PasswordBox x:Name="TxtConfirmPass" Background="Transparent"
                                 BorderThickness="0" Padding="12,0" FontSize="13"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="Pass_Changed"/>
                </Border>

                <!-- رسالة الخطأ -->
                <Border x:Name="ErrorPanel" Background="#FEF2F2" CornerRadius="8"
                        Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock x:Name="TxtError" Foreground="#DC2626"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- أزرار -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="حفظ كلمة المرور"
                            Style="{StaticResource PrimaryButton}" Height="42"
                            Click="BtnSave_Click"/>
                    <Button Grid.Column="2" Content="إلغاء"
                            Style="{StaticResource GhostButton}" Height="42"
                            Click="BtnCancel_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
