<Page x:Class="RestaurantMS.Desktop.Views.Menu.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft"
      Background="{StaticResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <Button Content="＋  إضافة صنف"    Style="{StaticResource PrimaryButton}" Click="BtnAddItem_Click"    Margin="0,0,8,0"/>
            <Button Content="＋  إضافة تصنيف"  Style="{StaticResource GhostButton}"   Click="BtnAddCategory_Click" Margin="0,0,8,0"/>
            <Button Content="🔄 تحديث"         Style="{StaticResource GhostButton}"   Click="BtnRefresh_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="GridItems" Style="{StaticResource DataGridStyle}"
                  AutoGenerateColumns="False" IsReadOnly="False"
                  SelectionChanged="GridItems_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="رقم"        Binding="{Binding item_id}"       Width="60"  IsReadOnly="True"/>
                <DataGridTextColumn Header="اسم الصنف"  Binding="{Binding item_name}"     Width="*"/>
                <DataGridTextColumn Header="التصنيف"    Binding="{Binding category_name}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="السعر"      Binding="{Binding price_fmt}"     Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="سعر التكلفة" Binding="{Binding cost_fmt}"     Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="الحالة"     Binding="{Binding status_txt}"    Width="90"  IsReadOnly="True"/>
                <DataGridTemplateColumn Header="إجراءات" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="تعديل"  Tag="{Binding}"
                                        Style="{StaticResource GhostButton}"
                                        Height="28" FontSize="12" Margin="2"
                                        Click="BtnEdit_Click"/>
                                <Button Content="حذف"    Tag="{Binding}"
                                        Style="{StaticResource DangerButton}"
                                        Height="28" FontSize="12" Margin="2"
                                        Click="BtnDelete_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
