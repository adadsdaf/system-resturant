<Window x:Class="RestaurantMS.Desktop.Views.Menu.CategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="#0d1117"
        Title="إضافة تصنيف" Height="200" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="اسم التصنيف الجديد"
                   Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
        <TextBox Grid.Row="1" x:Name="TxtName"
                 Style="{StaticResource DarkInput}" Height="42"
                 VerticalAlignment="Top"
                 KeyDown="TxtName_KeyDown"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Left" Margin="0,16,0,0">
            <Button Content="إضافة" Style="{StaticResource PrimaryButton}"
                    Width="90" Click="BtnAdd_Click" Margin="0,0,8,0"/>
            <Button Content="إلغاء" Style="{StaticResource GhostButton}"
                    Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
