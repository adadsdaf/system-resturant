<Window x:Class="RestaurantMS.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="نظام إدارة المطاعم — itQAN Soft"
        Height="780" Width="1320"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        MinWidth="1100" MinHeight="620">

    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Margin"          Value="0,1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#243447"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#1c3a5e"/>
            <Setter Property="Foreground" Value="#F7941D"/>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterBorder" Background="{StaticResource BgBrush}" CornerRadius="14" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.12" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============ الشريط الجانبي (داكن) ============ -->
            <Border Grid.Column="0" CornerRadius="14,0,0,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#1A2332" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F7941D" Offset="0"/>
                        <GradientStop Color="#1B4E9E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>0,0,1,0</Border.BorderThickness>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- شعار النظام -->
                    <StackPanel Grid.Row="0" Margin="0,16,0,0">
                        <Border HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Image Source="pack://application:,,,/Assets/itqansoft_logo.png"
                                   Width="80" Height="80"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <TextBlock Text="نظام إدارة المطاعم"
                                   Foreground="White" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock Text="Restaurant" Foreground="#F7941D" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Text="MS" Foreground="#1B4E9E" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <Border Height="1" Margin="16,14,16,8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F7941D" Offset="0"/>
                                    <GradientStop Color="#1B4E9E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <!-- قائمة التنقل -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10,0">
                        <StackPanel x:Name="NavPanel">
                            <TextBlock Text="الرئيسية" Foreground="#475569"
                                       FontSize="10" Margin="14,6,14,3" FontWeight="SemiBold"/>
                            <Button Tag="Dashboard" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="15" Width="24"/>
                                    <TextBlock Text="لوحة التحكم" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="Pos" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛒" FontSize="15" Width="24"/>
                                    <TextBlock Text="نقطة البيع" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="Kitchen" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👨‍🍳" FontSize="15" Width="24"/>
                                    <TextBlock Text="المطبخ" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="الإدارة" Foreground="#475569"
                                       FontSize="10" Margin="14,10,14,3" FontWeight="SemiBold"/>
                            <Button Tag="Menu" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="15" Width="24"/>
                                    <TextBlock Text="القائمة" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="Inventory" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" FontSize="15" Width="24"/>
                                    <TextBlock Text="المخزون" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="Customers" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="15" Width="24"/>
                                    <TextBlock Text="العملاء" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="Suppliers" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏭" FontSize="15" Width="24"/>
                                    <TextBlock Text="الموردون" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="المالية" Foreground="#475569"
                                       FontSize="10" Margin="14,10,14,3" FontWeight="SemiBold"/>
                            <Button Tag="Sales" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧾" FontSize="15" Width="24"/>
                                    <TextBlock Text="المبيعات" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="Reservations" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📅" FontSize="15" Width="24"/>
                                    <TextBlock Text="الحجوزات" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Tag="Reports" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📈" FontSize="15" Width="24"/>
                                    <TextBlock Text="التقارير" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="النظام" Foreground="#475569"
                                       FontSize="10" Margin="14,10,14,3" FontWeight="SemiBold"/>
                            <Button Tag="Admin" Click="Nav_Click" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙️" FontSize="15" Width="24"/>
                                    <TextBlock Text="الإدارة والإعدادات" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- بطاقة المستخدم -->
                    <Border Grid.Row="2" Margin="10,0,10,14">
                        <Border Background="#243447" CornerRadius="10" Padding="12">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F7941D" Offset="0"/>
                                    <GradientStop Color="#1B4E9E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>0,1,0,0</Border.BorderThickness>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Margin="0,0,10,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F7941D" Offset="0"/>
                                            <GradientStop Color="#1B4E9E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock x:Name="TxtUserInitial" Text="م"
                                               Foreground="White" FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtUserName" Foreground="White"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtUserRole" Foreground="#64748B" FontSize="11"/>
                                </StackPanel>
                                <Button Grid.Column="2" Width="32" Height="32"
                                        ToolTip="تسجيل الخروج" Cursor="Hand"
                                        Click="BtnLogout_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="6" Width="32" Height="32">
                                                <TextBlock Text="⏻" Foreground="#64748B"
                                                           FontSize="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#DC2626"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <!-- ============ المنطقة الرئيسية (فاتحة) ============ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- شريط العنوان -->
                <Border Grid.Row="0" Background="White"
                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid Margin="16,0">
                        <TextBlock x:Name="TxtPageTitle"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="TxtClock"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" VerticalAlignment="Center"
                                       Margin="0,0,16,0"/>
                            <Button Width="30" Height="30" Content="─"
                                    Background="Transparent" Foreground="{StaticResource MutedBrush}"
                                    BorderThickness="0" Cursor="Hand" FontSize="16"
                                    Click="BtnMinimize_Click"/>
                            <Button x:Name="BtnMaximizeToggle" Width="30" Height="30" Content="□"
                                    Background="Transparent" Foreground="{StaticResource MutedBrush}"
                                    BorderThickness="0" Cursor="Hand" FontSize="14"
                                    ToolTip="تكبير / استعادة" Click="BtnMaximize_Click"/>
                            <Button Width="30" Height="30" Content="✕"
                                    Background="Transparent" Foreground="{StaticResource MutedBrush}"
                                    BorderThickness="0" Cursor="Hand" FontSize="14"
                                    Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- محتوى الصفحة -->
                <Frame x:Name="MainFrame" Grid.Row="1"
                       NavigationUIVisibility="Hidden"
                       Background="{StaticResource BgBrush}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
