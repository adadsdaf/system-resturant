<Window x:Class="RestaurantMS.Desktop.Views.Inventory.StockHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="#0d1117"
        Title="سجل حركات المخزون" Height="480" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <DataGrid x:Name="GridHistory" Style="{StaticResource DataGridStyle}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="التاريخ"  Binding="{Binding date_fmt}"      Width="130"/>
                <DataGridTextColumn Header="المادة"   Binding="{Binding ingredient}"    Width="*"/>
                <DataGridTextColumn Header="النوع"    Binding="{Binding type_txt}"      Width="80"/>
                <DataGridTextColumn Header="الكمية"   Binding="{Binding qty_fmt}"       Width="90"/>
                <DataGridTextColumn Header="المنفذ"   Binding="{Binding user_name}"     Width="120"/>
                <DataGridTextColumn Header="ملاحظات"  Binding="{Binding notes}"         Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
