<Window x:Class="RestaurantMS.Desktop.Views.Inventory.StockMovementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FlowDirection="RightToLeft" Background="#0d1117"
        Height="300" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtTitle" Grid.Row="0" Foreground="White"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="المادة" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbItem" Style="{StaticResource DarkCombo}"
                      Height="40" Margin="0,0,0,12"
                      DisplayMemberPath="Display" SelectedValuePath="ingredient_id"/>
            <TextBlock Text="الكمية" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtQty" Style="{StaticResource DarkInput}" Height="40" Margin="0,0,0,12" Text="0"/>
            <TextBlock Text="ملاحظات" Foreground="#8b949e" FontSize="13" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNotes" Style="{StaticResource DarkInput}" Height="40"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
            <Button Content="تسجيل" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="إلغاء" Style="{StaticResource GhostButton}" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
