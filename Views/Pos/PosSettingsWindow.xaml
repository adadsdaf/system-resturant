<Window x:Class="RestaurantMS.Desktop.Views.Pos.PosSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إعدادات نقطة الكاشير"
        Width="900" Height="650"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="CanResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- رأس -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="⚙️" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="إعدادات نقطة الكاشير"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="White"
                    BorderBrush="{StaticResource BorderBrush2}">

            <!-- ===== تبويب الأقسام/التصنيفات ===== -->
            <TabItem Header="📂  الأقسام والتصنيفات" FontSize="13">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <!-- قائمة التصنيفات -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="التصنيفات الموجودة" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="➕  تصنيف جديد" Style="{StaticResource PrimaryButton}"
                                    Height="32" FontSize="12" Margin="12,0,0,0"
                                    Click="BtnNewCategory_Click"/>
                        </StackPanel>
                        <DataGrid Grid.Row="1" x:Name="GridCategories"
                                  Style="{StaticResource DataGridStyle}"
                                  SelectionChanged="GridCategories_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="رقم" Binding="{Binding category_id}" Width="50"/>
                                <DataGridTextColumn Header="اسم التصنيف" Binding="{Binding category_name}" Width="*"/>
                                <DataGridTextColumn Header="الترتيب" Binding="{Binding sort_order}" Width="70"/>
                                <DataGridCheckBoxColumn Header="نشط" Binding="{Binding is_active}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- نموذج تعديل التصنيف -->
                    <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock Text="بيانات التصنيف" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                            <TextBlock Text="اسم التصنيف *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtCatName" Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>

                            <TextBlock Text="الترتيب" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtCatOrder" Style="{StaticResource DarkInput}" Text="0" Margin="0,0,0,10"/>

                            <CheckBox x:Name="ChkCatActive" Content="تصنيف نشط" IsChecked="True"
                                      Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,16"/>

                            <Button x:Name="BtnSaveCategory" Content="💾  حفظ التصنيف"
                                    Style="{StaticResource PrimaryButton}" Height="36"
                                    Click="BtnSaveCategory_Click"/>
                            <Button x:Name="BtnDeleteCategory" Content="🗑  حذف التصنيف"
                                    Style="{StaticResource DangerButton}" Height="36" Margin="0,8,0,0"
                                    Click="BtnDeleteCategory_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== تبويب المنتجات ===== -->
            <TabItem Header="🍽  المنتجات والأصناف" FontSize="13">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- قائمة المنتجات -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="الأصناف" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="➕  صنف جديد" Style="{StaticResource PrimaryButton}"
                                    Height="32" FontSize="12" Margin="12,0,0,0"
                                    Click="BtnNewItem_Click"/>
                        </StackPanel>

                        <!-- بحث وفلتر -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="White" CornerRadius="6"
                                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Width="200" Margin="0,0,8,0">
                                <TextBox x:Name="TxtItemSearch" Background="Transparent"
                                         BorderThickness="0" Padding="8,6" FontSize="12"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         TextChanged="TxtItemSearch_Changed"/>
                            </Border>
                            <ComboBox x:Name="CmbCatFilter" Style="{StaticResource DarkCombo}"
                                      Width="160" FontSize="12" Height="32"
                                      SelectionChanged="CmbCatFilter_Changed"/>
                        </StackPanel>

                        <DataGrid Grid.Row="2" x:Name="GridItems"
                                  Style="{StaticResource DataGridStyle}"
                                  SelectionChanged="GridItems_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="رقم" Binding="{Binding item_id}" Width="50"/>
                                <DataGridTextColumn Header="اسم الصنف" Binding="{Binding item_name}" Width="*"/>
                                <DataGridTextColumn Header="التصنيف" Binding="{Binding category_name}" Width="120"/>
                                <DataGridTextColumn Header="السعر" Binding="{Binding price, StringFormat=N2}" Width="90"/>
                                <DataGridCheckBoxColumn Header="متاح" Binding="{Binding is_available}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- نموذج تعديل المنتج -->
                    <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10" Padding="16">
                        <StackPanel>
                            <TextBlock Text="بيانات الصنف" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                            <TextBlock Text="اسم الصنف *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtItemName" Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>

                            <TextBlock Text="التصنيف *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CmbItemCategory" Style="{StaticResource DarkCombo}"
                                      Height="36" Margin="0,0,0,10"/>

                            <TextBlock Text="سعر البيع *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtItemPrice" Style="{StaticResource DarkInput}" Text="0" Margin="0,0,0,10"/>

                            <TextBlock Text="سعر التكلفة" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtItemCost" Style="{StaticResource DarkInput}" Text="0" Margin="0,0,0,10"/>

                            <TextBlock Text="الوصف" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtItemDesc" Style="{StaticResource DarkInput}"
                                     Height="60" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <CheckBox x:Name="ChkItemAvailable" Content="الصنف متاح للبيع"
                                      IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}"
                                      FontSize="12" Margin="0,0,0,16"/>

                            <Button x:Name="BtnSaveItem" Content="💾  حفظ الصنف"
                                    Style="{StaticResource PrimaryButton}" Height="36"
                                    Click="BtnSaveItem_Click"/>
                            <Button x:Name="BtnDeleteItem" Content="🗑  حذف الصنف"
                                    Style="{StaticResource DangerButton}" Height="36" Margin="0,8,0,0"
                                    Click="BtnDeleteItem_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== تبويب إعدادات الفاتورة ===== -->
            <TabItem Header="🧾  إعدادات الفاتورة" FontSize="13">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- العمود الأيمن: بيانات المطعم -->
                        <StackPanel Grid.Column="0">
                            <!-- بيانات المطعم على الفاتورة -->
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🏪  بيانات المطعم على الفاتورة"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                                    <TextBlock Text="اسم المطعم" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtRestaurantName" Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>

                                    <TextBlock Text="رقم الهاتف" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtReceiptPhone" Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>

                                    <TextBlock Text="العنوان" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtReceiptAddress" Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>

                                    <TextBlock Text="الرقم الضريبي" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtTaxNumber" Style="{StaticResource DarkInput}" Margin="0,0,0,10"/>

                                    <TextBlock Text="نص التذييل (أسفل الفاتورة)" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtReceiptFooter" Style="{StaticResource DarkInput}"
                                             Height="60" TextWrapping="Wrap" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- ما يظهر على الفاتورة -->
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="📋  ما يظهر على الفاتورة"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                                    <CheckBox x:Name="ChkShowLogo" Content="إظهار شعار المطعم"
                                              IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="ChkShowOrderNum" Content="إظهار رقم الطلب"
                                              IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="ChkShowDateTime" Content="إظهار التاريخ والوقت"
                                              IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="ChkShowCashier" Content="إظهار اسم الكاشير"
                                              IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="ChkShowTable" Content="إظهار رقم الطاولة"
                                              IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- العمود الأيسر: إعدادات الطباعة -->
                        <StackPanel Grid.Column="2">
                            <!-- الفاتورة الكبيرة -->
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📄  الفواتير الكبيرة (A4)"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                                    <CheckBox x:Name="ChkLargeCustomer"
                                              Content="طباعة فاتورة كبيرة للعميل (نسخة العميل)"
                                              IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="ChkLargeStaff"
                                              Content="طباعة فاتورة كبيرة للعامل (نسخة المطعم)"
                                              IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- القصاصات الصغيرة 80mm -->
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🖨  القصاصات الصغيرة (80mm)"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                                    <CheckBox x:Name="ChkSmallSlips"
                                              Content="طباعة قصاصات صغيرة للمطبخ/الأقسام"
                                              IsChecked="True" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12" Margin="0,0,0,12"/>

                                    <TextBlock Text="تقسيم القصاصات حسب:" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <RadioButton x:Name="RbSlipByCategory" Content="القسم / التصنيف"
                                                     IsChecked="True" GroupName="SlipBy"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     FontSize="12" Margin="0,0,16,0"/>
                                        <RadioButton x:Name="RbSlipByGroup" Content="المجموعة"
                                                     GroupName="SlipBy"
                                                     Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock Text="اسم/معرّف الطابعة الحرارية" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtPrinterName" Style="{StaticResource DarkInput}"/>
                                </StackPanel>
                            </Border>

                            <!-- معاينة وطباعة تجريبية -->
                            <Border Background="#EFF6FF" CornerRadius="10" Padding="16"
                                    BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="💡  معاينة الفاتورة"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#1D4ED8" Margin="0,0,0,8"/>
                                    <TextBlock Text="يمكنك معاينة شكل الفاتورة قبل الطباعة الفعلية"
                                               Foreground="#3B82F6" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <Button Content="👁  معاينة فاتورة تجريبية"
                                            Style="{StaticResource BlueButton}" Height="36" FontSize="12"
                                            Click="BtnPreviewReceipt_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- أزرار أسفل -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,12,0,0">
            <Button Content="💾  حفظ الإعدادات" Style="{StaticResource PrimaryButton}"
                    Height="40" FontSize="14" Margin="0,0,10,0"
                    Click="BtnSaveSettings_Click"/>
            <Button Content="✕  إغلاق" Style="{StaticResource GhostButton}"
                    Height="40" FontSize="13" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
