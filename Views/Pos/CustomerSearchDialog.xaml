<Window x:Class="RestaurantMS.Desktop.Views.Pos.CustomerSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="بحث عن عميل" Height="340" Width="420"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="البحث برقم الهاتف"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                Height="44" Margin="0,0,0,12">
            <Grid Margin="12,0">
                <TextBlock Text="أدخل رقم الهاتف..." Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" x:Name="Ph"/>
                <TextBox x:Name="TxtPhone" Background="Transparent"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderThickness="0" FontSize="14" VerticalAlignment="Center"
                         CaretBrush="{StaticResource AccentBrush}"
                         TextChanged="TxtPhone_Changed"/>
            </Grid>
        </Border>

        <ListBox Grid.Row="2" x:Name="LstResults"
                 Background="White" Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                 FontSize="13" SelectionChanged="LstResults_Changed"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,12,0,0">
            <Button Content="اختيار" Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0" Click="BtnSelect_Click"/>
            <Button Content="إلغاء" Style="{StaticResource GhostButton}" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
