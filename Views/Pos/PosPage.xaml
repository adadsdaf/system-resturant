<Page x:Class="RestaurantMS.Desktop.Views.Pos.PosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft"
      Background="#0d1117">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ======= القائمة (يسار) ======= -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- بحث -->
            <Border Grid.Row="0" Background="#21262d" BorderBrush="#30363d"
                    BorderThickness="1" CornerRadius="8" Height="42" Margin="0,0,0,12">
                <Grid Margin="12,0">
                    <TextBlock Text="🔍  ابحث عن صنف..." Foreground="#30363d"
                               VerticalAlignment="Center" FontSize="13"
                               x:Name="SearchPlaceholder"/>
                    <TextBox x:Name="TxtSearch" Background="Transparent"
                             Foreground="White" BorderThickness="0"
                             FontSize="13" VerticalAlignment="Center"
                             CaretBrush="White" TextChanged="TxtSearch_Changed"/>
                </Grid>
            </Border>

            <!-- التصنيفات -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled" Margin="0,0,0,12">
                <StackPanel x:Name="CatPanel" Orientation="Horizontal"/>
            </ScrollViewer>

            <!-- الأصناف -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="ItemsPanel" Margin="0,4"/>
            </ScrollViewer>
        </Grid>

        <!-- ======= السلة (يمين) ======= -->
        <Border Grid.Column="1" Background="#161b22" CornerRadius="12">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- رأس السلة -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="🛒  السلة" Foreground="White"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                    <!-- بيانات العميل -->
                    <Border Background="#21262d" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="العميل" Foreground="#8b949e" FontSize="11"/>
                                <TextBlock x:Name="TxtCustomerInfo"
                                           Text="زبون عادي" Foreground="White" FontSize="13"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="بحث 🔍"
                                    Style="{StaticResource GhostButton}"
                                    FontSize="12" Click="BtnSearchCustomer_Click"/>
                        </Grid>
                    </Border>

                    <!-- رقم الطاولة -->
                    <Border Background="#21262d" CornerRadius="8" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="الطاولة:" Foreground="#8b949e"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CmbTable" Grid.Column="1"
                                      Background="#0d1117" Foreground="White"
                                      FontSize="13"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- عناصر السلة -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="CartPanel"/>
                </ScrollViewer>

                <!-- الإجماليات والدفع -->
                <StackPanel Grid.Row="2">
                    <Separator Background="#334155" Margin="0,12"/>

                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="المجموع الفرعي:" Foreground="#8b949e" FontSize="13"/>
                        <TextBlock x:Name="TxtSubtotal" Text="0.00"
                                   Foreground="White" FontSize="13"
                                   HorizontalAlignment="Left"/>
                    </Grid>

                    <!-- خصم -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="خصم %:" Foreground="#8b949e"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="#21262d" CornerRadius="6"
                                Height="32" Margin="8,0">
                            <TextBox x:Name="TxtDiscount" Text="0"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0" FontSize="13"
                                     VerticalAlignment="Center" Padding="8,0"
                                     CaretBrush="White" TextChanged="TxtDiscount_Changed"/>
                        </Border>
                        <TextBlock x:Name="TxtDiscountAmt" Grid.Column="2"
                                   Text="-0.00" Foreground="#ef4444" FontSize="13"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="الإجمالي:" Foreground="White"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtTotal" Text="0.00 ريال"
                                   Foreground="#f59e0b" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Left"/>
                    </Grid>

                    <!-- طريقة الدفع -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="RbCash" Content="كاش" IsChecked="True"
                                     Foreground="White" FontSize="13" Margin="0,0,16,0"
                                     GroupName="Payment" Checked="Payment_Changed"/>
                        <RadioButton x:Name="RbCard" Content="بطاقة"
                                     Foreground="White" FontSize="13" Margin="0,0,16,0"
                                     GroupName="Payment" Checked="Payment_Changed"/>
                        <RadioButton x:Name="RbTransfer" Content="تحويل"
                                     Foreground="White" FontSize="13"
                                     GroupName="Payment" Checked="Payment_Changed"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="🗑 مسح السلة"
                                Style="{StaticResource GhostButton}"
                                Margin="0,0,8,0" Click="BtnClearCart_Click"/>
                        <Button Grid.Column="1" Content="✅  تأكيد الطلب"
                                Style="{StaticResource PrimaryButton}"
                                FontSize="15" Padding="20,10"
                                Click="BtnConfirmOrder_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
