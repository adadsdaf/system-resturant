<Page x:Class="RestaurantMS.Desktop.Views.Pos.PosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      FlowDirection="RightToLeft"
      Background="{StaticResource BgBrush}">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ======= القائمة (يسار) ======= -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- بحث -->
            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush2}"
                    BorderThickness="1" CornerRadius="8" Height="44" Margin="0,0,0,12">
                <Grid Margin="12,0">
                    <TextBlock Text="🔍  ابحث عن صنف..."
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center" FontSize="13"
                               x:Name="SearchPlaceholder"/>
                    <TextBox x:Name="TxtSearch" Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderThickness="0" FontSize="13" VerticalAlignment="Center"
                             CaretBrush="{StaticResource AccentBrush}"
                             TextChanged="TxtSearch_Changed"/>
                </Grid>
            </Border>

            <!-- التصنيفات -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled" Margin="0,0,0,12">
                <StackPanel x:Name="CatPanel" Orientation="Horizontal"/>
            </ScrollViewer>

            <!-- الأصناف -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="ItemsPanel" Margin="0,4"/>
            </ScrollViewer>
        </Grid>

        <!-- ======= السلة (يمين) ======= -->
        <Border Grid.Column="1" Background="White" CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.07" Color="#000000"/>
            </Border.Effect>
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- رأس السلة -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="🛒  الطلب الحالي"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="15" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="الطاولة: " Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CmbTable" Style="{StaticResource DarkCombo}"
                                  Height="30" MinWidth="90" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- بيانات العميل -->
                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        Padding="10,8" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtCustomerInfo" Text="زبون عادي"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <Button Content="اختر عميلاً" Style="{StaticResource GhostButton}"
                                Height="26" FontSize="11" Margin="auto,0,0,0"
                                HorizontalAlignment="Left"
                                Click="BtnSearchCustomer_Click"/>
                    </StackPanel>
                </Border>

                <!-- عناصر السلة -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                    <StackPanel x:Name="CartPanel"/>
                </ScrollViewer>

                <!-- المجاميع -->
                <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        Padding="12,10" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="المجموع الفرعي" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="TxtSubtotal" Text="0.00"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="12" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="الخصم %" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                            <TextBox x:Name="TxtDiscount" Background="White"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                     FontSize="12" HorizontalAlignment="Left"
                                     Width="60" Text="0"
                                     TextChanged="TxtDiscount_Changed"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="مبلغ الخصم" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="TxtDiscountAmt" Text="-0.00"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="12" HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="الضريبة" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="TxtTax" Text="0.00"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" HorizontalAlignment="Left"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,6,0,6"/>
                        <Grid>
                            <TextBlock Text="الإجمالي" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTotal" Text="0.00 ريال"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="16" FontWeight="Bold" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- طريقة الدفع والأزرار -->
                <StackPanel Grid.Row="4">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton x:Name="RbCash" Content="كاش" IsChecked="True"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     Margin="0,0,12,0" FontSize="13"
                                     Click="Payment_Changed"/>
                        <RadioButton x:Name="RbCard" Content="بطاقة"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     Margin="0,0,12,0" FontSize="13"
                                     Click="Payment_Changed"/>
                        <RadioButton x:Name="RbTransfer" Content="تحويل"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     FontSize="13" Click="Payment_Changed"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="✅  إتمام الطلب"
                                Style="{StaticResource PrimaryButton}" Height="44" FontSize="14"
                                Click="BtnConfirmOrder_Click"/>
                        <Button Grid.Column="2" Content="🗑"
                                Style="{StaticResource DangerButton}" Height="44" FontSize="18"
                                Click="BtnClearCart_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
