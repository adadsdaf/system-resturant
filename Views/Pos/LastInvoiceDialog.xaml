<Window x:Class="RestaurantMS.Desktop.Views.Pos.LastInvoiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تفاصيل آخر فاتورة"
        Width="700" Height="580"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- رأس -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🧾" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <StackPanel>
                <TextBlock Text="تفاصيل آخر فاتورة"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="TxtOrderMeta" Text="..."
                           Foreground="{StaticResource MutedBrush}" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- بيانات الطلب -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="رقم الطلب" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtOrderId" Text="-"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="العميل" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtCustomer" Text="-"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="الدفع" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtPayMethod" Text="-"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="التاريخ" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtDate" Text="-"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- جدول الأصناف -->
        <Border Grid.Row="2" Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
            <DataGrid x:Name="GridItems" Style="{StaticResource DataGridStyle}"
                      Margin="0" CanUserReorderColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="الصنف"     Binding="{Binding ItemName}"   Width="*"/>
                    <DataGridTextColumn Header="التصنيف"   Binding="{Binding CategoryName}" Width="120"/>
                    <DataGridTextColumn Header="الكمية"    Binding="{Binding Quantity}"    Width="70"  ElementStyle="{StaticResource {x:Type TextBlock}}"/>
                    <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice, StringFormat=N2}"  Width="100"/>
                    <DataGridTextColumn Header="الإجمالي"  Binding="{Binding Subtotal, StringFormat=N2}"   Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- المجاميع -->
        <Border Grid.Row="3" Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                Padding="16,10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="المجموع الفرعي" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtSubtotal" Text="0.00" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="الخصم" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtDiscount" Text="0.00" FontSize="13"
                               Foreground="{StaticResource DangerBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="الضريبة" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtTax" Text="0.00" FontSize="13"
                               Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="20,0,0,0">
                    <TextBlock Text="الإجمالي" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    <TextBlock x:Name="TxtTotal" Text="0.00 ريال" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- أزرار -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,12,0,0">
            <Button Content="🖨  طباعة فاتورة عميل" Style="{StaticResource PrimaryButton}"
                    Height="38" FontSize="13" Margin="0,0,8,0"
                    Click="BtnPrintCustomer_Click"/>
            <Button Content="🖨  طباعة فاتورة عامل" Style="{StaticResource BlueButton}"
                    Height="38" FontSize="13" Margin="0,0,8,0"
                    Click="BtnPrintStaff_Click"/>
            <Button Content="📄  قصاصات المطبخ" Style="{StaticResource GhostButton}"
                    Height="38" FontSize="13" Margin="0,0,8,0"
                    Click="BtnPrintSlips_Click"/>
            <Button Content="✕  إغلاق" Style="{StaticResource GhostButton}"
                    Height="38" FontSize="13" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
