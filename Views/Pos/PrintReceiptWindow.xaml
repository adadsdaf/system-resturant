<Window x:Class="RestaurantMS.Desktop.Views.Pos.PrintReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="معاينة الفاتورة"
        Width="750" Height="680"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="CanResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- رأس -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🖨" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtTitle" Text="معاينة الفاتورة"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- عارض المستند -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
            <FlowDocumentScrollViewer x:Name="DocViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      IsToolBarVisible="False"
                                      Zoom="100"
                                      MinZoom="50" MaxZoom="200"/>
        </Border>

        <!-- أزرار -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,12,0,0">
            <Button Content="🖨  طباعة" Style="{StaticResource PrimaryButton}"
                    Height="38" FontSize="13" Margin="0,0,8,0"
                    Click="BtnPrint_Click"/>
            <Button Content="✕  إغلاق" Style="{StaticResource GhostButton}"
                    Height="38" FontSize="13" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
