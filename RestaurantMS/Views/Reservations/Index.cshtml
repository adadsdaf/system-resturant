@{
    ViewBag.Title = "الحجوزات";
    ViewBag.PageTitle = "إدارة الحجوزات";
    ViewBag.PageIcon = "fa-calendar-alt";
    var reservations = (IEnumerable<dynamic>)(ViewBag.Reservations ?? new List<dynamic>());
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}
<div class="page-header">
  <h1><i class="fas fa-calendar-alt"></i> الحجوزات (@reservations.Count())</h1>
  <button class="btn btn-primary" onclick="openModal('addResModal')"><i class="fas fa-plus"></i> حجز جديد</button>
</div>
<div class="card">
  <div class="table-wrap">
    <table class="data-table">
      <thead><tr><th>#</th><th>العميل</th><th>الهاتف</th><th>عدد الأشخاص</th><th>التاريخ</th><th>الوقت</th><th>الطاولة</th><th>الحالة</th><th>الإجراءات</th></tr></thead>
      <tbody>
        @if (!reservations.Any())
        { <tr><td colspan="9" style="text-align:center;padding:40px;color:#888">لا توجد حجوزات</td></tr> }
        else
        {
          foreach (var r in reservations)
          {
            string status = (string)r.status;
            string badgeClass = status == "Confirmed" ? "badge-success" : status == "Cancelled" ? "badge-danger" : status == "Seated" ? "badge-info" : "badge-warning";
            string statusAr = status == "Confirmed" ? "مؤكد" : status == "Cancelled" ? "ملغى" : status == "Seated" ? "جالس" : status == "No Show" ? "لم يحضر" : status;
            <tr>
              <td>@r.reservation_id</td>
              <td><strong>@r.customer_name</strong></td>
              <td dir="ltr">@r.phone</td>
              <td><i class="fas fa-users" style="color:var(--blue)"></i> @r.party_size</td>
              <td>@(((DateOnly?)r.reservation_date)?.ToString("yyyy/MM/dd") ?? ((DateTime?)r.reservation_date)?.ToString("yyyy/MM/dd") ?? r.reservation_date?.ToString() ?? "")</td>
              <td>@(r.reservation_time?.ToString()?.Substring(0,5) ?? "")</td>
              <td>@(string.IsNullOrEmpty((string?)r.table_number) ? "—" : (string)r.table_number)</td>
              <td><span class="badge @badgeClass">@statusAr</span></td>
              <td>
                @if (status == "Confirmed") { <button class="btn btn-info btn-sm" onclick="updateStatus(@r.reservation_id,'Seated')"><i class="fas fa-chair"></i></button> }
                @if (status != "Cancelled") { <button class="btn btn-warning btn-sm" onclick="updateStatus(@r.reservation_id,'Cancelled')"><i class="fas fa-ban"></i></button> }
                <button class="btn btn-danger btn-sm" onclick="deleteRes(@r.reservation_id)"><i class="fas fa-trash"></i></button>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>

<div class="modal-overlay" id="addResModal">
  <div class="modal-box">
    <div class="modal-header"><h3><i class="fas fa-calendar-plus"></i> حجز جديد</h3><button class="modal-close" onclick="closeModal('addResModal')">×</button></div>
    <form method="POST" action="/reservations/add">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">اسم العميل *</label><input type="text" name="customer_name" class="form-control" required></div>
        <div class="form-group"><label class="form-label">رقم الهاتف</label><input type="text" name="phone" class="form-control"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label class="form-label">عدد الأشخاص *</label><input type="number" name="party_size" class="form-control" min="1" value="2" required></div>
          <div class="form-group"><label class="form-label">رقم الطاولة</label><input type="text" name="table_number" class="form-control"></div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label class="form-label">التاريخ *</label><input type="date" name="reservation_date" class="form-control" value="@today" required></div>
          <div class="form-group"><label class="form-label">الوقت *</label><input type="time" name="reservation_time" class="form-control" required></div>
        </div>
        <div class="form-group"><label class="form-label">ملاحظات</label><textarea name="notes" class="form-control" rows="2"></textarea></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('addResModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حجز</button></div>
    </form>
  </div>
</div>
@section ExtraScripts {
<script>
async function updateStatus(id,status){
  const res=await apiPost('/reservations/update_status',{reservation_id:id,status});
  if(res.success){showToast('تم تحديث الحالة','success');setTimeout(()=>location.reload(),600);}
}
async function deleteRes(id){
  if(!confirm('هل تريد حذف هذا الحجز؟'))return;
  const res=await apiPost('/reservations/delete',{reservation_id:id});
  if(res.success){showToast('تم حذف الحجز','success');setTimeout(()=>location.reload(),600);}
}
</script>
}
