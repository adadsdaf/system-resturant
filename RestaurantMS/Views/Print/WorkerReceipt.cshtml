@{
    Layout = null;
    var order = ViewBag.Order;
    var items = (IEnumerable<dynamic>)(ViewBag.Items ?? new List<dynamic>());
    var settings = (Dictionary<string,string>)(ViewBag.Settings ?? new Dictionary<string,string>());
    string S(string k) => settings.ContainsKey(k) ? (settings[k] ?? "") : "";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>إيصال الكاشير #@order?.order_id</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Cairo',monospace;direction:rtl;padding:10px;font-size:12px;max-width:320px;margin:0 auto}
.header{text-align:center;border-bottom:2px dashed #333;padding-bottom:8px;margin-bottom:10px}
.title{font-size:16px;font-weight:800}
.row{display:flex;justify-content:space-between;margin-bottom:3px}
.bold{font-weight:700}
.items{border-top:1px dashed #888;padding:6px 0;margin:8px 0;border-bottom:1px dashed #888}
.item-row{display:grid;grid-template-columns:auto 1fr auto;gap:8px;padding:3px 0}
.total-section{padding-top:6px;border-top:1px dashed #ccc}
.big-total{font-weight:800;font-size:16px;border-top:2px solid #333;padding-top:4px;margin-top:4px;display:flex;justify-content:space-between}
@@media print{button{display:none}}
</style>
</head>
<body>
<div class="header">
  <div class="title">إيصال الكاشير</div>
  <div style="font-size:11px;color:#666">@S("restaurant_name")</div>
</div>
<div class="row"><span>طلب #</span><span class="bold">@(order?.order_id)</span></div>
<div class="row"><span>الكاشير:</span><span>@(order?.cashier_name ?? "")</span></div>
<div class="row"><span>الفرع:</span><span>@(order?.branch_name ?? "")</span></div>
<div class="row"><span>التاريخ:</span><span dir="ltr">@(((DateTime?)order?.created_at)?.ToString("yyyy/MM/dd HH:mm") ?? "")</span></div>
<div class="row"><span>طريقة الدفع:</span><span class="bold">@(order?.payment_method ?? "")</span></div>

<div class="items">
  @foreach (var item in items)
  { <div class="item-row"><span class="bold">@item.quantity×</span><span>@item.item_name</span><span>@((decimal)item.subtotal).ToString("N2")</span></div> }
</div>

<div class="total-section">
  <div class="row"><span>المجموع</span><span>@((decimal)(order?.subtotal ?? 0)).ToString("N2")</span></div>
  @if ((decimal)(order?.discount_amount ?? 0) > 0)
  { <div class="row" style="color:red"><span>خصم</span><span>-@((decimal)order.discount_amount).ToString("N2")</span></div> }
  @if ((decimal)(order?.tax_amount ?? 0) > 0)
  { <div class="row" style="color:#555"><span>ضريبة</span><span>@((decimal)order.tax_amount).ToString("N2")</span></div> }
  <div class="big-total"><span>الإجمالي</span><span>@((decimal)(order?.total_amount ?? 0)).ToString("N2") @S("currency")</span></div>
</div>

<div style="margin-top:12px;text-align:center">
  <button onclick="window.print()" style="padding:8px 20px;background:#1a2332;color:#fff;border:none;border-radius:6px;cursor:pointer;font-family:'Cairo',sans-serif;font-size:13px">🖨️ طباعة</button>
</div>
</body>
</html>
