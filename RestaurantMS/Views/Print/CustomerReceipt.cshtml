@{
    Layout = null;
    var order = ViewBag.Order;
    var items = (IEnumerable<dynamic>)(ViewBag.Items ?? new List<dynamic>());
    var settings = (Dictionary<string,string>)(ViewBag.Settings ?? new Dictionary<string,string>());
    string S(string k) => settings.ContainsKey(k) ? (settings[k] ?? "") : "";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>فاتورة العميل #@order?.order_id</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Cairo',monospace;direction:rtl;padding:10px;font-size:12px;max-width:320px;margin:0 auto}
.header{text-align:center;border-bottom:2px dashed #333;padding-bottom:10px;margin-bottom:10px}
.rest-name{font-size:18px;font-weight:800;margin-bottom:2px}
.branch-name{font-size:12px;color:#555}
.row{display:flex;justify-content:space-between;margin-bottom:3px}
.bold{font-weight:700}
.items-table{width:100%;border-top:1px dashed #888;border-bottom:1px dashed #888;padding:6px 0;margin:8px 0}
.item-row{display:grid;grid-template-columns:1fr auto auto;gap:6px;margin-bottom:3px}
.totals{border-top:1px dashed #888;padding-top:6px;margin-top:4px}
.total-bold{font-weight:800;font-size:15px;border-top:2px solid #333;padding-top:4px;margin-top:4px}
.footer{text-align:center;margin-top:10px;font-size:11px;color:#666;border-top:1px dashed #ccc;padding-top:8px}
@@media print{button{display:none}body{padding:0;max-width:100%}}
</style>
</head>
<body>
<div class="header">
  <div class="rest-name">@S("restaurant_name")</div>
  <div class="branch-name">@(order?.branch_name ?? "")</div>
  @if (!string.IsNullOrEmpty(order?.branch_phone)) { <div style="font-size:11px" dir="ltr">📞 @order.branch_phone</div> }
</div>

<div class="row"><span>رقم الطلب:</span><span class="bold">#@(order?.order_id)</span></div>
<div class="row"><span>العميل:</span><span>@(order?.customer_name ?? "زبون")</span></div>
<div class="row"><span>الكاشير:</span><span>@(order?.cashier_name ?? "")</span></div>
<div class="row"><span>التاريخ:</span><span dir="ltr">@(((DateTime?)order?.created_at)?.ToString("yyyy/MM/dd HH:mm") ?? "")</span></div>
<div class="row"><span>طريقة الدفع:</span><span class="bold">@(order?.payment_method ?? "")</span></div>

<div class="items-table">
  <div class="item-row" style="font-size:10px;color:#888;border-bottom:1px dashed #ddd;padding-bottom:4px;margin-bottom:4px">
    <span>الصنف</span><span>الكمية</span><span>الإجمالي</span>
  </div>
  @foreach (var item in items)
  {
    <div class="item-row">
      <span>@item.item_name</span>
      <span>@item.quantity</span>
      <span>@((decimal)item.subtotal).ToString("N2")</span>
    </div>
  }
</div>

<div class="totals">
  <div class="row"><span>المجموع الفرعي</span><span>@((decimal)(order?.subtotal ?? 0)).ToString("N2") @S("currency")</span></div>
  @if ((decimal)(order?.discount_amount ?? 0) > 0)
  { <div class="row" style="color:red"><span>خصم</span><span>-@((decimal)order.discount_amount).ToString("N2") @S("currency")</span></div> }
  @if ((decimal)(order?.tax_amount ?? 0) > 0)
  { <div class="row" style="color:#666"><span>ضريبة القيمة المضافة</span><span>@((decimal)order.tax_amount).ToString("N2") @S("currency")</span></div> }
  <div class="row total-bold"><span>الإجمالي</span><span>@((decimal)(order?.total_amount ?? 0)).ToString("N2") @S("currency")</span></div>
</div>

<div class="footer">@S("receipt_footer")</div>
<div style="margin-top:12px;text-align:center">
  <button onclick="window.print()" style="padding:8px 20px;background:#1a2332;color:#fff;border:none;border-radius:6px;cursor:pointer;font-family:'Cairo',sans-serif;font-size:13px">🖨️ طباعة</button>
</div>
</body>
</html>
