@{
    Layout = null;
    var inv = ViewBag.Invoice;
    var settings = (Dictionary<string,string>)(ViewBag.Settings ?? new Dictionary<string,string>());
    string S(string k) => settings.ContainsKey(k) ? (settings[k] ?? "") : "";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>فاتورة مبيعات @(inv?.invoice_number)</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Cairo',sans-serif;direction:rtl;padding:20px;max-width:600px;margin:0 auto;font-size:13px}
.header{text-align:center;border-bottom:3px solid #1a2332;padding-bottom:16px;margin-bottom:20px}
.rest-name{font-size:24px;font-weight:800;color:#1a2332}
.invoice-label{font-size:18px;font-weight:700;color:#F7941D;margin-top:4px}
.invoice-num{font-size:14px;color:#666}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;padding:16px;background:#f8f9fa;border-radius:8px}
.info-block label{font-size:11px;color:#888;font-weight:700;display:block;margin-bottom:3px}
.info-block span{font-weight:600;font-size:13px}
.totals{margin-top:16px;border:1px solid #e0e0e0;border-radius:8px;overflow:hidden}
.total-row{display:flex;justify-content:space-between;padding:10px 16px;border-bottom:1px solid #f0f0f0}
.total-row.final{background:#1a2332;color:#fff;font-weight:800;font-size:16px;border-bottom:none}
.footer{text-align:center;margin-top:20px;font-size:11px;color:#888;border-top:1px dashed #ccc;padding-top:12px}
@@media print{button{display:none}}
</style>
</head>
<body>
<div class="header">
  <div class="rest-name">@S("restaurant_name")</div>
  <div class="invoice-label">فاتورة مبيعات</div>
  <div class="invoice-num">@(inv?.invoice_number)</div>
</div>

<div class="info-grid">
  <div class="info-block"><label>العميل</label><span>@(inv?.customer_name ?? "—")</span></div>
  <div class="info-block"><label>الحالة</label><span>@(inv?.status ?? "")</span></div>
  <div class="info-block"><label>طريقة الدفع</label><span>@(inv?.payment_method ?? "")</span></div>
  <div class="info-block"><label>بواسطة</label><span>@(inv?.created_by_name ?? "")</span></div>
  <div class="info-block"><label>التاريخ</label><span>@(((DateTime?)inv?.created_at)?.ToString("yyyy/MM/dd HH:mm") ?? "")</span></div>
</div>

@if (!string.IsNullOrEmpty((string?)inv?.notes)) { <div style="background:#fff3cd;padding:10px 14px;border-radius:6px;font-size:12px;margin-bottom:16px">📝 @inv.notes</div> }

<div class="totals">
  <div class="total-row"><span>المجموع الفرعي</span><span>@((decimal)(inv?.subtotal ?? 0)).ToString("N2") @S("currency")</span></div>
  @if ((decimal)(inv?.discount_amount ?? 0) > 0)
  { <div class="total-row" style="color:red"><span>الخصم</span><span>-@((decimal)inv.discount_amount).ToString("N2") @S("currency")</span></div> }
  @if ((decimal)(inv?.tax_amount ?? 0) > 0)
  { <div class="total-row" style="color:#666"><span>ضريبة القيمة المضافة</span><span>@((decimal)inv.tax_amount).ToString("N2") @S("currency")</span></div> }
  <div class="total-row final"><span>الإجمالي</span><span>@((decimal)(inv?.total_amount ?? 0)).ToString("N2") @S("currency")</span></div>
</div>

<div class="footer">@S("receipt_footer")</div>
<div style="margin-top:20px;text-align:center">
  <button onclick="window.print()" style="padding:10px 24px;background:#1a2332;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Cairo',sans-serif;font-size:14px;font-weight:700">🖨️ طباعة</button>
</div>
</body>
</html>
