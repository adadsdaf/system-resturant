@{
    ViewBag.Title = "الإعدادات";
    ViewBag.PageTitle = "إعدادات النظام";
    ViewBag.PageIcon = "fa-cogs";
    var users = (IEnumerable<dynamic>)(ViewBag.Users ?? new List<dynamic>());
    var roles = (IEnumerable<dynamic>)(ViewBag.Roles ?? new List<dynamic>());
    var branches = (IEnumerable<dynamic>)(ViewBag.Branches ?? new List<dynamic>());
    var settings = (Dictionary<string,string?>)(ViewBag.Settings ?? new Dictionary<string,string?>());
    var auditLogs = (IEnumerable<dynamic>)(ViewBag.AuditLogs ?? new List<dynamic>());
    var tables = (IEnumerable<dynamic>)(ViewBag.Tables ?? new List<dynamic>());
    string S(string k) => settings.ContainsKey(k) ? (settings[k] ?? "") : "";
}
@section ExtraHead {
<style>
.tabs{display:flex;gap:4px;background:#f0f2f5;padding:6px;border-radius:10px;margin-bottom:20px;flex-wrap:wrap}
.tab-btn{padding:8px 18px;border:none;background:none;border-radius:7px;cursor:pointer;font-family:'Cairo',sans-serif;font-size:13px;font-weight:600;color:#666;transition:all .2s}
.tab-btn.active{background:#fff;color:var(--orange);box-shadow:0 2px 6px rgba(0,0,0,.1)}
.tab-content{display:none}.tab-content.active{display:block}
</style>
}
<div class="page-header"><h1><i class="fas fa-cogs"></i> إعدادات النظام</h1></div>

<div class="tabs">
  <button class="tab-btn active" onclick="showTab('users')"><i class="fas fa-users"></i> المستخدمون</button>
  <button class="tab-btn" onclick="showTab('settings')"><i class="fas fa-sliders-h"></i> الإعدادات</button>
  <button class="tab-btn" onclick="showTab('tables')"><i class="fas fa-table"></i> الطاولات</button>
  <button class="tab-btn" onclick="showTab('audit')"><i class="fas fa-list-alt"></i> سجل النشاطات</button>
</div>

<div class="tab-content active" id="tab-users">
  <div class="page-header" style="margin-bottom:12px">
    <h2 style="font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px"><i class="fas fa-users" style="color:var(--orange)"></i> المستخدمون (@users.Count())</h2>
    <button class="btn btn-primary" onclick="openModal('addUserModal')"><i class="fas fa-user-plus"></i> إضافة مستخدم</button>
  </div>
  <div class="card">
    <div class="table-wrap">
      <table class="data-table">
        <thead><tr><th>اسم المستخدم</th><th>الاسم الكامل</th><th>الدور</th><th>الفرع</th><th>آخر دخول</th><th>الحالة</th><th>إجراءات</th></tr></thead>
        <tbody>
          @foreach (var u in users)
          {
            bool active = (bool)u.is_active;
            <tr>
              <td><strong>@u.username</strong></td>
              <td>@u.full_name</td>
              <td><span class="badge badge-secondary">@u.role_name</span></td>
              <td>@u.branch_name</td>
              <td style="font-size:12px;color:#888">@(((DateTime?)u.last_login)?.ToString("yyyy/MM/dd") ?? "لم يسجل")</td>
              <td>@if(active){<span class="badge badge-success">نشط</span>}else{<span class="badge badge-danger">موقوف</span>}</td>
              <td>
                <button class="btn btn-light btn-sm" onclick="editUser(@u.user_id,'@((string)u.full_name).Replace("'","\\'")',@u.role_id,@u.branch_id)"><i class="fas fa-edit"></i></button>
                <button class="btn btn-warning btn-sm" onclick="resetPwd(@u.user_id,'@((string)u.username)')"><i class="fas fa-key"></i></button>
                <button class="btn btn-sm @(active?"btn-danger":"btn-success")" onclick="toggleUser(@u.user_id)"><i class="fas fa-toggle-@(active?"off":"on")"></i></button>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="tab-content" id="tab-settings">
  <div class="card">
    <div class="card-header"><h2><i class="fas fa-sliders-h"></i> إعدادات المطعم</h2></div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="form-group"><label class="form-label">اسم المطعم</label><input type="text" id="set_restaurant_name" class="form-control" value="@S("restaurant_name")"></div>
        <div class="form-group"><label class="form-label">العملة</label><input type="text" id="set_currency" class="form-control" value="@S("currency")"></div>
        <div class="form-group"><label class="form-label">تفعيل الضريبة</label>
          <select id="set_tax_enabled" class="form-control">
            <option value="0" @(S("tax_enabled")=="0"?"selected":"")>معطل</option>
            <option value="1" @(S("tax_enabled")=="1"?"selected":"")>مفعل</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label">نسبة الضريبة %</label><input type="number" id="set_tax_rate" class="form-control" value="@S("tax_rate")"></div>
        <div class="form-group" style="grid-column:1/-1"><label class="form-label">نص تذييل الفاتورة</label><input type="text" id="set_receipt_footer" class="form-control" value="@S("receipt_footer")"></div>
      </div>
      <button class="btn btn-primary" onclick="saveAllSettings()"><i class="fas fa-save"></i> حفظ الإعدادات</button>
    </div>
  </div>
</div>

<div class="tab-content" id="tab-tables">
  <div class="page-header" style="margin-bottom:12px">
    <h2 style="font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px"><i class="fas fa-table" style="color:var(--orange)"></i> الطاولات (@tables.Count())</h2>
    <button class="btn btn-primary" onclick="openModal('addTableModal')"><i class="fas fa-plus"></i> إضافة طاولة</button>
  </div>
  <div class="card">
    <div class="table-wrap">
      <table class="data-table">
        <thead><tr><th>رقم الطاولة</th><th>السعة</th><th>إجراءات</th></tr></thead>
        <tbody>
          @if (!tables.Any())
          { <tr><td colspan="3" style="text-align:center;padding:20px;color:#888">لا توجد طاولات</td></tr> }
          else
          {
            foreach (var t in tables)
            { <tr><td><strong>@t.table_number</strong></td><td>@t.capacity أشخاص</td><td><button class="btn btn-danger btn-sm" onclick="deleteTable(@t.table_id)"><i class="fas fa-trash"></i></button></td></tr> }
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="tab-content" id="tab-audit">
  <div class="card">
    <div class="card-header"><h2><i class="fas fa-list-alt"></i> سجل النشاطات</h2></div>
    <div class="table-wrap">
      <table class="data-table">
        <thead><tr><th>المستخدم</th><th>الإجراء</th><th>التفاصيل</th><th>IP</th><th>التاريخ</th></tr></thead>
        <tbody>
          @if (!auditLogs.Any())
          { <tr><td colspan="5" style="text-align:center;padding:20px;color:#888">لا يوجد سجل</td></tr> }
          else
          { foreach (var l in auditLogs)
            { <tr><td>@l.username</td><td>@l.action</td><td style="font-size:12px;color:#666;max-width:200px">@l.details</td><td dir="ltr" style="font-size:11px;color:#888">@l.ip_address</td><td style="font-size:11px;color:#888">@(((DateTime?)l.created_at)?.ToString("yyyy/MM/dd HH:mm") ?? "")</td></tr> }
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add User Modal -->
<div class="modal-overlay" id="addUserModal">
  <div class="modal-box">
    <div class="modal-header"><h3><i class="fas fa-user-plus"></i> إضافة مستخدم</h3><button class="modal-close" onclick="closeModal('addUserModal')">×</button></div>
    <form method="POST" action="/admin/create_user">
      <div class="modal-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label class="form-label">اسم المستخدم *</label><input type="text" name="username" class="form-control" required></div>
          <div class="form-group"><label class="form-label">الاسم الكامل *</label><input type="text" name="full_name" class="form-control" required></div>
        </div>
        <div class="form-group"><label class="form-label">البريد الإلكتروني</label><input type="email" name="email" class="form-control"></div>
        <div class="form-group"><label class="form-label">كلمة المرور *</label><input type="password" name="password" class="form-control" required></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label class="form-label">الدور *</label>
            <select name="role_id" class="form-control" required>
              @foreach (var r in roles) { <option value="@r.role_id">@r.role_name</option> }
            </select>
          </div>
          <div class="form-group"><label class="form-label">الفرع *</label>
            <select name="branch_id" class="form-control" required>
              @foreach (var b in branches) { <option value="@b.branch_id">@b.arabic_name</option> }
            </select>
          </div>
        </div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('addUserModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> إنشاء</button></div>
    </form>
  </div>
</div>

<!-- Edit User Modal -->
<div class="modal-overlay" id="editUserModal">
  <div class="modal-box">
    <div class="modal-header"><h3><i class="fas fa-edit"></i> تعديل المستخدم</h3><button class="modal-close" onclick="closeModal('editUserModal')">×</button></div>
    <form method="POST" action="/admin/update_user">
      <input type="hidden" name="user_id" id="editUserId">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">الاسم الكامل *</label><input type="text" name="full_name" id="editUserFullName" class="form-control" required></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label class="form-label">الدور</label>
            <select name="role_id" id="editUserRoleId" class="form-control">
              @foreach (var r in roles) { <option value="@r.role_id">@r.role_name</option> }
            </select>
          </div>
          <div class="form-group"><label class="form-label">الفرع</label>
            <select name="branch_id" id="editUserBranchId" class="form-control">
              @foreach (var b in branches) { <option value="@b.branch_id">@b.arabic_name</option> }
            </select>
          </div>
        </div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('editUserModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button></div>
    </form>
  </div>
</div>

<!-- Reset Password Modal -->
<div class="modal-overlay" id="resetPwdModal">
  <div class="modal-box" style="max-width:400px">
    <div class="modal-header"><h3><i class="fas fa-key"></i> إعادة تعيين كلمة المرور - <span id="resetPwdUser"></span></h3><button class="modal-close" onclick="closeModal('resetPwdModal')">×</button></div>
    <div class="modal-body">
      <div class="form-group"><label class="form-label">كلمة المرور الجديدة *</label><input type="password" id="newPassword" class="form-control"></div>
    </div>
    <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('resetPwdModal')">إلغاء</button><button class="btn btn-primary" onclick="doResetPwd()"><i class="fas fa-save"></i> حفظ</button></div>
  </div>
</div>

<!-- Add Table Modal -->
<div class="modal-overlay" id="addTableModal">
  <div class="modal-box" style="max-width:380px">
    <div class="modal-header"><h3><i class="fas fa-plus"></i> إضافة طاولة</h3><button class="modal-close" onclick="closeModal('addTableModal')">×</button></div>
    <form method="POST" action="/admin/add_table">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">رقم الطاولة *</label><input type="text" name="table_number" class="form-control" required></div>
        <div class="form-group"><label class="form-label">السعة (عدد الأشخاص)</label><input type="number" name="capacity" class="form-control" min="1" value="4"></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('addTableModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> إضافة</button></div>
    </form>
  </div>
</div>

@section ExtraScripts {
<script>
function showTab(tab){
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  event.target.classList.add('active');
}
function editUser(id,name,roleId,branchId){
  document.getElementById('editUserId').value=id;
  document.getElementById('editUserFullName').value=name;
  document.getElementById('editUserRoleId').value=roleId;
  document.getElementById('editUserBranchId').value=branchId;
  openModal('editUserModal');
}
let resetUserId=null;
function resetPwd(id,username){resetUserId=id;document.getElementById('resetPwdUser').textContent=username;openModal('resetPwdModal');}
async function doResetPwd(){
  const pwd=document.getElementById('newPassword').value;
  if(!pwd){showToast('أدخل كلمة المرور الجديدة','warning');return;}
  const res=await apiPost('/admin/reset_password',{user_id:resetUserId,new_password:pwd});
  if(res.success){showToast('تم إعادة تعيين كلمة المرور','success');closeModal('resetPwdModal');}
}
async function toggleUser(id){const r=await apiPost('/admin/toggle_user',{user_id:id});if(r.success){showToast('تم تغيير الحالة','success');setTimeout(()=>location.reload(),600);}}
async function deleteTable(id){if(!confirm('حذف هذه الطاولة؟'))return;const r=await apiPost('/admin/delete_table',{table_id:id});if(r.success){showToast('تم الحذف','success');setTimeout(()=>location.reload(),600);}}
async function saveAllSettings(){
  const keys=['restaurant_name','currency','tax_enabled','tax_rate','receipt_footer'];
  for(const k of keys){
    const el=document.getElementById('set_'+k);
    if(el)await apiPost('/admin/save_setting',{key:k,value:el.value});
  }
  showToast('تم حفظ الإعدادات','success');
}
</script>
}
