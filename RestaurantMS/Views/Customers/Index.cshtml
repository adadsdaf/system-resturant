@{
    ViewBag.Title = "العملاء";
    ViewBag.PageTitle = "إدارة العملاء";
    ViewBag.PageIcon = "fa-users";
    var customers = (IEnumerable<dynamic>)(ViewBag.Customers ?? new List<dynamic>());
}
<div class="page-header">
  <h1><i class="fas fa-users"></i> العملاء (@customers.Count())</h1>
  <button class="btn btn-primary" onclick="openModal('addCustomerModal')"><i class="fas fa-plus"></i> إضافة عميل</button>
</div>
<div class="card">
  <div class="card-header">
    <h2><i class="fas fa-list"></i> قائمة العملاء</h2>
    <div class="search-bar" style="width:260px">
      <i class="fas fa-search"></i>
      <input type="text" placeholder="بحث..." oninput="this.closest('.card').querySelector('tbody').querySelectorAll('tr').forEach(tr=>tr.style.display=tr.textContent.toLowerCase().includes(this.value.toLowerCase())?'':'none')">
    </div>
  </div>
  <div class="table-wrap">
    <table class="data-table">
      <thead><tr><th>#</th><th>الاسم</th><th>الهاتف</th><th>البريد</th><th>النقاط</th><th>الطلبات</th><th>الإجمالي</th><th>الحالة</th><th>الإجراءات</th></tr></thead>
      <tbody>
        @if (!customers.Any())
        { <tr><td colspan="9" style="text-align:center;padding:40px;color:#888">لا يوجد عملاء</td></tr> }
        else
        {
          foreach (var c in customers)
          {
            bool active = (bool)c.is_active;
            <tr>
              <td>@c.customer_id</td>
              <td><strong>@c.full_name</strong></td>
              <td dir="ltr">@c.phone</td>
              <td>@c.email</td>
              <td><span class="badge badge-primary">@c.points نقطة</span></td>
              <td>@c.total_orders</td>
              <td><strong>@((decimal)c.total_spent).ToString("N2")</strong></td>
              <td>@if (active) { <span class="badge badge-success">نشط</span> } else { <span class="badge badge-danger">موقوف</span> }</td>
              <td>
                <button class="btn btn-light btn-sm" onclick="editCustomer(@c.customer_id,'@((string)c.full_name).Replace("'","\\'")',@((string?)c.phone==null?"''":(string?)c.phone == ""?"''":(string?)c.phone),'@((string?)c.email??"")')"><i class="fas fa-edit"></i></button>
                <button class="btn btn-sm @(active?"btn-warning":"btn-success")" onclick="toggleCustomer(@c.customer_id)"><i class="fas fa-toggle-@(active?"off":"on")"></i></button>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>

<div class="modal-overlay" id="addCustomerModal">
  <div class="modal-box">
    <div class="modal-header"><h3><i class="fas fa-user-plus"></i> إضافة عميل</h3><button class="modal-close" onclick="closeModal('addCustomerModal')">×</button></div>
    <form method="POST" action="/customers/add">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">الاسم الكامل *</label><input type="text" name="full_name" class="form-control" required></div>
        <div class="form-group"><label class="form-label">رقم الهاتف</label><input type="text" name="phone" class="form-control"></div>
        <div class="form-group"><label class="form-label">البريد الإلكتروني</label><input type="email" name="email" class="form-control"></div>
        <div class="form-group"><label class="form-label">العنوان</label><input type="text" name="address" class="form-control"></div>
        <div class="form-group"><label class="form-label">ملاحظات</label><textarea name="notes" class="form-control" rows="2"></textarea></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('addCustomerModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button></div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="editCustomerModal">
  <div class="modal-box">
    <div class="modal-header"><h3><i class="fas fa-edit"></i> تعديل بيانات العميل</h3><button class="modal-close" onclick="closeModal('editCustomerModal')">×</button></div>
    <form method="POST" action="/customers/update">
      <input type="hidden" name="customer_id" id="editCustId">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">الاسم الكامل *</label><input type="text" name="full_name" id="editCustName" class="form-control" required></div>
        <div class="form-group"><label class="form-label">رقم الهاتف</label><input type="text" name="phone" id="editCustPhone" class="form-control"></div>
        <div class="form-group"><label class="form-label">البريد الإلكتروني</label><input type="email" name="email" id="editCustEmail" class="form-control"></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('editCustomerModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button></div>
    </form>
  </div>
</div>
@section ExtraScripts {
<script>
function editCustomer(id,name,phone,email){
  document.getElementById('editCustId').value=id;
  document.getElementById('editCustName').value=name;
  document.getElementById('editCustPhone').value=phone;
  document.getElementById('editCustEmail').value=email;
  openModal('editCustomerModal');
}
async function toggleCustomer(id){
  const res=await apiPost('/customers/toggle',{customer_id:id});
  if(res.success){showToast('تم تغيير الحالة','success');setTimeout(()=>location.reload(),600);}
}
</script>
}
