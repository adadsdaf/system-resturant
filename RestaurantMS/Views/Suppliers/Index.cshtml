@{
    ViewBag.Title = "الموردون";
    ViewBag.PageTitle = "إدارة الموردين";
    ViewBag.PageIcon = "fa-truck";
    var suppliers = (IEnumerable<dynamic>)(ViewBag.Suppliers ?? new List<dynamic>());
    var purchaseOrders = (IEnumerable<dynamic>)(ViewBag.PurchaseOrders ?? new List<dynamic>());
    var ingredients = (IEnumerable<dynamic>)(ViewBag.Ingredients ?? new List<dynamic>());
}
<div class="page-header">
  <h1><i class="fas fa-truck"></i> الموردون</h1>
  <button class="btn btn-primary" onclick="openModal('addSupModal')"><i class="fas fa-plus"></i> إضافة مورد</button>
</div>

<div style="display:grid;grid-template-columns:1fr;gap:20px">
  <div class="card">
    <div class="card-header"><h2><i class="fas fa-list"></i> قائمة الموردين</h2></div>
    <div class="table-wrap">
      <table class="data-table">
        <thead><tr><th>المورد</th><th>المسؤول</th><th>الهاتف</th><th>الطلبات</th><th>إجمالي الشراء</th><th>الحالة</th><th>إجراءات</th></tr></thead>
        <tbody>
          @foreach (var s in suppliers)
          {
            bool active = (bool)s.is_active;
            <tr>
              <td><strong>@s.supplier_name</strong></td>
              <td>@s.contact_person</td>
              <td dir="ltr">@s.phone</td>
              <td>@s.total_orders</td>
              <td><strong>@((decimal)s.total_spent).ToString("N2")</strong></td>
              <td>@if(active){<span class="badge badge-success">نشط</span>}else{<span class="badge badge-danger">موقوف</span>}</td>
              <td>
                <button class="btn btn-light btn-sm" onclick="editSup(@s.supplier_id,'@((string)s.supplier_name).Replace("'","\\'")')"><i class="fas fa-edit"></i></button>
                <button class="btn btn-secondary btn-sm" onclick="openCreatePO(@s.supplier_id,'@((string)s.supplier_name).Replace("'","\\'")')"><i class="fas fa-file-alt"></i> أمر شراء</button>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-header"><h2><i class="fas fa-file-invoice"></i> أوامر الشراء</h2></div>
    <div class="table-wrap">
      <table class="data-table">
        <thead><tr><th>الرقم</th><th>المورد</th><th>الحالة</th><th>الإجمالي</th><th>بواسطة</th><th>التاريخ</th><th>إجراءات</th></tr></thead>
        <tbody>
          @if (!purchaseOrders.Any())
          { <tr><td colspan="7" style="text-align:center;padding:20px;color:#888">لا توجد أوامر شراء</td></tr> }
          else
          {
            foreach (var po in purchaseOrders)
            {
              string poStatus = (string)po.status;
              string badgeClass = poStatus=="Received"?"badge-success":poStatus=="Draft"?"badge-warning":"badge-secondary";
              string statusAr = poStatus=="Received"?"مستلم":poStatus=="Draft"?"مسودة":"قيد التنفيذ";
              <tr>
                <td><strong>@po.po_number</strong></td>
                <td>@po.supplier_name</td>
                <td><span class="badge @badgeClass">@statusAr</span></td>
                <td><strong>@((decimal)po.total_amount).ToString("N2")</strong></td>
                <td>@po.created_by_name</td>
                <td style="font-size:12px;color:#666">@(((DateTime?)po.created_at)?.ToString("yyyy/MM/dd") ?? "")</td>
                <td>
                  @if (poStatus != "Received")
                  {
                    <form method="POST" action="/suppliers/receive_po" style="display:inline">
                      <input type="hidden" name="po_id" value="@po.po_id">
                      <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-check"></i> استلام</button>
                    </form>
                  }
                </td>
              </tr>
            }
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal-overlay" id="addSupModal">
  <div class="modal-box">
    <div class="modal-header"><h3><i class="fas fa-truck"></i> إضافة مورد</h3><button class="modal-close" onclick="closeModal('addSupModal')">×</button></div>
    <form method="POST" action="/suppliers/add">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">اسم المورد *</label><input type="text" name="supplier_name" class="form-control" required></div>
        <div class="form-group"><label class="form-label">شخص التواصل</label><input type="text" name="contact_person" class="form-control"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label class="form-label">الهاتف</label><input type="text" name="phone" class="form-control"></div>
          <div class="form-group"><label class="form-label">البريد الإلكتروني</label><input type="email" name="email" class="form-control"></div>
        </div>
        <div class="form-group"><label class="form-label">العنوان</label><textarea name="address" class="form-control" rows="2"></textarea></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('addSupModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button></div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="createPOModal">
  <div class="modal-box" style="max-width:600px">
    <div class="modal-header"><h3><i class="fas fa-file-alt"></i> إنشاء أمر شراء - <span id="poSupName"></span></h3><button class="modal-close" onclick="closeModal('createPOModal')">×</button></div>
    <div class="modal-body">
      <input type="hidden" id="poSupId">
      <div class="form-group"><label class="form-label">ملاحظات</label><input type="text" id="poNotes" class="form-control"></div>
      <div style="margin-bottom:12px">
        <div style="display:grid;grid-template-columns:2fr 1fr 1fr auto;gap:8px;margin-bottom:8px">
          <select id="poIngredient" class="form-control">
            @foreach (var i in ingredients) { <option value="@i.ingredient_id" data-name="@i.ingredient_name">@i.ingredient_name (@i.unit)</option> }
          </select>
          <input type="number" id="poQty" class="form-control" placeholder="الكمية" step="0.01" min="0.01">
          <input type="number" id="poUnitCost" class="form-control" placeholder="التكلفة" step="0.01" min="0">
          <button class="btn btn-primary" onclick="addPOItem()"><i class="fas fa-plus"></i></button>
        </div>
        <div id="poItemsList"></div>
      </div>
    </div>
    <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('createPOModal')">إلغاء</button><button class="btn btn-primary" onclick="submitPO()"><i class="fas fa-save"></i> إنشاء أمر الشراء</button></div>
  </div>
</div>
@section ExtraScripts {
<script>
let poItems=[];
function openCreatePO(id,name){poItems=[];document.getElementById('poSupId').value=id;document.getElementById('poSupName').textContent=name;document.getElementById('poItemsList').innerHTML='';openModal('createPOModal');}
function addPOItem(){
  const sel=document.getElementById('poIngredient');
  const qty=parseFloat(document.getElementById('poQty').value)||0;
  const cost=parseFloat(document.getElementById('poUnitCost').value)||0;
  if(!qty){showToast('أدخل الكمية','warning');return;}
  poItems.push({IngredientId:parseInt(sel.value),IngredientName:sel.options[sel.selectedIndex].dataset.name,Quantity:qty,UnitCost:cost});
  renderPOItems();
}
function renderPOItems(){
  document.getElementById('poItemsList').innerHTML=poItems.map((i,idx)=>`
    <div style="display:flex;gap:8px;align-items:center;padding:6px 8px;background:#f8f9fa;border-radius:6px;margin-bottom:4px">
      <span style="flex:1">${i.IngredientName}</span><span>×${i.Quantity}</span><span style="color:var(--success)">${(i.Quantity*i.UnitCost).toFixed(2)}</span>
      <button class="btn btn-danger btn-sm" onclick="poItems.splice(${idx},1);renderPOItems()"><i class="fas fa-times"></i></button>
    </div>`).join('');
}
async function submitPO(){
  if(!poItems.length){showToast('أضف أصنافاً للأمر','warning');return;}
  const res=await apiPost('/suppliers/create_po',{SupplierId:parseInt(document.getElementById('poSupId').value),Notes:document.getElementById('poNotes').value,Items:poItems});
  if(res.success){showToast('تم إنشاء أمر الشراء: '+res.po_number,'success');setTimeout(()=>location.reload(),800);}
  else showToast(res.error||'خطأ','error');
}
function editSup(id,name){}
</script>
}
