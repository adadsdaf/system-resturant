@{
    ViewBag.Title = "قائمة الطعام";
    ViewBag.PageTitle = "قائمة الطعام";
    ViewBag.PageIcon = "fa-utensils";
    var categories = (IEnumerable<dynamic>)(ViewBag.Categories ?? new List<dynamic>());
    var items = (IEnumerable<dynamic>)(ViewBag.Items ?? new List<dynamic>());
}
<div class="page-header">
  <h1><i class="fas fa-utensils"></i> قائمة الطعام</h1>
  <div style="display:flex;gap:8px">
    <button class="btn btn-primary" onclick="openModal('addItemModal')"><i class="fas fa-plus"></i> إضافة صنف</button>
    <button class="btn btn-secondary" onclick="openModal('addCatModal')"><i class="fas fa-plus"></i> إضافة تصنيف</button>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h2><i class="fas fa-list"></i> الأصناف (@items.Count())</h2>
    <div class="search-bar" style="width:280px">
      <i class="fas fa-search"></i>
      <input type="text" placeholder="بحث..." id="searchInput" oninput="filterTable()">
    </div>
  </div>
  <div class="table-wrap">
    <table class="data-table" id="itemsTable">
      <thead>
        <tr><th>#</th><th>اسم الصنف</th><th>التصنيف</th><th>السعر</th><th>التكلفة</th><th>الحالة</th><th>الإجراءات</th></tr>
      </thead>
      <tbody>
        @if (!items.Any())
        {
          <tr><td colspan="7" style="text-align:center;padding:40px;color:#888">لا توجد أصناف</td></tr>
        }
        else
        {
          foreach (var item in items)
          {
            bool avail = (bool)item.is_available;
            <tr>
              <td>@item.item_id</td>
              <td><strong>@item.item_name</strong></td>
              <td><span class="badge badge-secondary">@item.category_name</span></td>
              <td><strong style="color:var(--success)">@((decimal)item.price).ToString("N2")</strong></td>
              <td style="color:var(--text-muted)">@((decimal)item.cost_price).ToString("N2")</td>
              <td>
                @if (avail) { <span class="badge badge-success">متاح</span> }
                else { <span class="badge badge-danger">غير متاح</span> }
              </td>
              <td>
                <button class="btn btn-light btn-sm" onclick="editItem(@item.item_id,'@((string)item.item_name).Replace("'","\\'")',@item.category_id,@((decimal)item.price).ToString(System.Globalization.CultureInfo.InvariantCulture),@((decimal)item.cost_price).ToString(System.Globalization.CultureInfo.InvariantCulture),'@((string)(item.description ?? "")).Replace("'","\\'")')"><i class="fas fa-edit"></i></button>
                <button class="btn btn-sm @(avail ? "btn-warning" : "btn-success")" onclick="toggleItem(@item.item_id, this)"><i class="fas fa-toggle-@(avail ? "off" : "on")"></i></button>
                <button class="btn btn-danger btn-sm" onclick="deleteItem(@item.item_id)"><i class="fas fa-trash"></i></button>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>

<!-- Add Item Modal -->
<div class="modal-overlay" id="addItemModal">
  <div class="modal-box">
    <div class="modal-header"><h3><i class="fas fa-plus"></i> إضافة صنف جديد</h3><button class="modal-close" onclick="closeModal('addItemModal')">×</button></div>
    <form method="POST" action="/menu/add_item">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">التصنيف *</label>
          <select name="category_id" class="form-control" required>
            @foreach (var c in categories) { <option value="@c.category_id">@c.category_name</option> }
          </select>
        </div>
        <div class="form-group"><label class="form-label">اسم الصنف *</label><input type="text" name="item_name" class="form-control" required></div>
        <div class="form-group"><label class="form-label">الوصف</label><input type="text" name="description" class="form-control"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label class="form-label">السعر *</label><input type="number" name="price" class="form-control" step="0.01" min="0" required></div>
          <div class="form-group"><label class="form-label">التكلفة</label><input type="number" name="cost_price" class="form-control" step="0.01" min="0" value="0"></div>
        </div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('addItemModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button></div>
    </form>
  </div>
</div>

<!-- Edit Item Modal -->
<div class="modal-overlay" id="editItemModal">
  <div class="modal-box">
    <div class="modal-header"><h3><i class="fas fa-edit"></i> تعديل الصنف</h3><button class="modal-close" onclick="closeModal('editItemModal')">×</button></div>
    <form method="POST" action="/menu/update_item">
      <input type="hidden" name="item_id" id="editItemId">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">التصنيف *</label>
          <select name="category_id" id="editCatId" class="form-control" required>
            @foreach (var c in categories) { <option value="@c.category_id">@c.category_name</option> }
          </select>
        </div>
        <div class="form-group"><label class="form-label">اسم الصنف *</label><input type="text" name="item_name" id="editItemName" class="form-control" required></div>
        <div class="form-group"><label class="form-label">الوصف</label><input type="text" name="description" id="editItemDesc" class="form-control"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group"><label class="form-label">السعر *</label><input type="number" name="price" id="editItemPrice" class="form-control" step="0.01" min="0" required></div>
          <div class="form-group"><label class="form-label">التكلفة</label><input type="number" name="cost_price" id="editItemCost" class="form-control" step="0.01" min="0"></div>
        </div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('editItemModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button></div>
    </form>
  </div>
</div>

<!-- Add Category Modal -->
<div class="modal-overlay" id="addCatModal">
  <div class="modal-box" style="max-width:420px">
    <div class="modal-header"><h3><i class="fas fa-tag"></i> إضافة تصنيف</h3><button class="modal-close" onclick="closeModal('addCatModal')">×</button></div>
    <form method="POST" action="/menu/add_category">
      <div class="modal-body">
        <div class="form-group"><label class="form-label">اسم التصنيف *</label><input type="text" name="category_name" class="form-control" required></div>
        <div class="form-group"><label class="form-label">الوصف</label><input type="text" name="description" class="form-control"></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-light" onclick="closeModal('addCatModal')">إلغاء</button><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button></div>
    </form>
  </div>
</div>

@section ExtraScripts {
<script>
function filterTable(){
  const q=document.getElementById('searchInput').value.toLowerCase();
  document.querySelectorAll('#itemsTable tbody tr').forEach(tr=>{
    tr.style.display=tr.textContent.toLowerCase().includes(q)?'':'none';
  });
}
function editItem(id,name,catId,price,cost,desc){
  document.getElementById('editItemId').value=id;
  document.getElementById('editItemName').value=name;
  document.getElementById('editCatId').value=catId;
  document.getElementById('editItemPrice').value=price;
  document.getElementById('editItemCost').value=cost;
  document.getElementById('editItemDesc').value=desc;
  openModal('editItemModal');
}
async function toggleItem(id,btn){
  const res=await apiPost('/menu/toggle_item',{item_id:id});
  if(res.success){showToast('تم تغيير حالة الصنف','success');setTimeout(()=>location.reload(),800);}
}
async function deleteItem(id){
  if(!confirm('هل تريد حذف هذا الصنف؟'))return;
  const res=await apiPost('/menu/delete_item',{item_id:id});
  if(res.success){showToast('تم حذف الصنف','success');setTimeout(()=>location.reload(),800);}
  else showToast(res.error||'خطأ','error');
}
</script>
}
