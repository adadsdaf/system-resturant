@{
    ViewBag.Title = "حركات المخزون";
    ViewBag.PageTitle = "سجل حركات المخزون";
    ViewBag.PageIcon = "fa-history";
    var txs = (IEnumerable<dynamic>)(ViewBag.Transactions ?? new List<dynamic>());
}
<div class="page-header">
  <h1><i class="fas fa-history"></i> حركات المخزون</h1>
  <a href="/inventory" class="btn btn-light"><i class="fas fa-arrow-right"></i> العودة للمخزون</a>
</div>
<div class="card">
  <div class="table-wrap">
    <table class="data-table">
      <thead><tr><th>#</th><th>المادة</th><th>النوع</th><th>الكمية</th><th>التكلفة</th><th>المرجع</th><th>بواسطة</th><th>التاريخ</th></tr></thead>
      <tbody>
        @if (!txs.Any())
        { <tr><td colspan="8" style="text-align:center;padding:40px;color:#888">لا توجد حركات</td></tr> }
        else
        {
          foreach (var t in txs)
          {
            bool isIn = (string)t.transaction_type == "StockIn";
            <tr>
              <td>@t.transaction_id</td>
              <td><strong>@t.ingredient_name</strong></td>
              <td><span class="badge @(isIn ? "badge-success" : "badge-danger")">@(isIn ? "وارد" : "صادر")</span></td>
              <td style="color:@(isIn ? "var(--success)" : "var(--danger)");font-weight:700">@(isIn?"+":"-")@((decimal)t.quantity).ToString("N2")</td>
              <td>@((decimal)t.unit_cost).ToString("N2")</td>
              <td>@t.reference_no</td>
              <td>@t.created_by_name</td>
              <td style="font-size:12px;color:#666">@(((DateTime?)t.created_at)?.ToString("yyyy/MM/dd HH:mm") ?? "")</td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>
