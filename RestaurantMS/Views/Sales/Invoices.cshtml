@{
    ViewBag.Title = "فواتير المبيعات";
    ViewBag.PageTitle = "فواتير المبيعات";
    ViewBag.PageIcon = "fa-file-invoice-dollar";
    var invoices = (IEnumerable<dynamic>)(ViewBag.Invoices ?? new List<dynamic>());
}
<div class="page-header">
  <h1><i class="fas fa-file-invoice-dollar"></i> فواتير المبيعات</h1>
  <a href="/sales/returns" class="btn btn-light"><i class="fas fa-undo-alt"></i> مردود المبيعات</a>
</div>
<div class="card">
  <div class="card-header">
    <h2><i class="fas fa-list"></i> الفواتير (@invoices.Count())</h2>
    <div class="search-bar" style="width:260px">
      <i class="fas fa-search"></i>
      <input type="text" placeholder="بحث..." oninput="this.closest('.card').querySelector('tbody').querySelectorAll('tr').forEach(tr=>tr.style.display=tr.textContent.toLowerCase().includes(this.value.toLowerCase())?'':'none')">
    </div>
  </div>
  <div class="table-wrap">
    <table class="data-table">
      <thead><tr><th>رقم الفاتورة</th><th>العميل</th><th>الإجمالي</th><th>طريقة الدفع</th><th>الحالة</th><th>بواسطة</th><th>التاريخ</th><th>إجراءات</th></tr></thead>
      <tbody>
        @if (!invoices.Any())
        { <tr><td colspan="8" style="text-align:center;padding:40px;color:#888">لا توجد فواتير</td></tr> }
        else
        {
          foreach (var inv in invoices)
          {
            string status = (string)inv.status;
            <tr>
              <td><strong>@inv.invoice_number</strong></td>
              <td>@inv.customer_name</td>
              <td><strong>@((decimal)inv.total_amount).ToString("N2")</strong></td>
              <td>@inv.payment_method</td>
              <td><span class="badge @(status=="Active"?"badge-success":status=="Cancelled"?"badge-danger":"badge-secondary")">@(status=="Active"?"نشطة":status=="Cancelled"?"ملغاة":"مرجعة")</span></td>
              <td>@inv.created_by_name</td>
              <td style="font-size:12px;color:#666">@(((DateTime?)inv.created_at)?.ToString("yyyy/MM/dd HH:mm") ?? "")</td>
              <td>
                <a href="/print/invoice/@inv.invoice_id" target="_blank" class="btn btn-light btn-sm"><i class="fas fa-print"></i></a>
                @if (status == "Active")
                {
                  <button class="btn btn-danger btn-sm" onclick="cancelInvoice(@inv.invoice_id)"><i class="fas fa-times"></i></button>
                }
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>
@section ExtraScripts {
<script>
async function cancelInvoice(id){
  if(!confirm('إلغاء هذه الفاتورة؟'))return;
  const res=await apiPost('/sales/invoices/delete',{invoice_id:id});
  if(res.success){showToast('تم إلغاء الفاتورة','success');setTimeout(()=>location.reload(),600);}
}
</script>
}
