@{
    ViewBag.Title = "جلسات المستخدمين";
    ViewBag.PageTitle = "جلسات المستخدمين";
    ViewBag.PageIcon = "fa-user-clock";
    var sessions = (IEnumerable<dynamic>)(ViewBag.Sessions ?? new List<dynamic>());
}
<div class="page-header"><h1><i class="fas fa-user-clock"></i> جلسات المستخدمين</h1></div>
<div class="card">
  <div class="table-wrap">
    <table class="data-table">
      <thead><tr><th>#</th><th>المستخدم</th><th>الاسم</th><th>وقت الدخول</th><th>وقت الخروج</th><th>IP</th><th>الحالة</th></tr></thead>
      <tbody>
        @if (!sessions.Any())
        { <tr><td colspan="7" style="text-align:center;padding:40px;color:#888">لا توجد جلسات</td></tr> }
        else
        {
          foreach (var s in sessions)
          {
            string status = (string)s.session_status;
            <tr>
              <td>@s.session_id</td>
              <td><strong>@s.username</strong></td>
              <td>@s.full_name</td>
              <td>@(((DateTime?)s.login_time)?.ToString("yyyy/MM/dd HH:mm") ?? "")</td>
              <td style="color:#888">@(((DateTime?)s.logout_time)?.ToString("yyyy/MM/dd HH:mm") ?? "—")</td>
              <td dir="ltr" style="font-size:12px;color:#666">@s.ip_address</td>
              <td><span class="badge @(status=="active"?"badge-success":"badge-secondary")">@(status=="active"?"نشط":"مغلقة")</span></td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>
