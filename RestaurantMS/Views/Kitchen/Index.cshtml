@{
    ViewBag.Title = "شاشة المطبخ";
    ViewBag.PageTitle = "شاشة المطبخ - KDS";
    ViewBag.PageIcon = "fa-fire";
    var orders = (IEnumerable<dynamic>)(ViewBag.Orders ?? new List<dynamic>());
}
@section ExtraHead {
<style>
.kitchen-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
.ko-card{background:#fff;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.08);overflow:hidden;transition:transform .2s}
.ko-card:hover{transform:translateY(-2px)}
.ko-card.status-Pending{border-top:4px solid #e74c3c}
.ko-card.status-Preparing{border-top:4px solid #f39c12}
.ko-card.status-Ready{border-top:4px solid #27ae60}
.ko-header{padding:12px 16px;background:#f8f9fa;border-bottom:1px solid #e0e0e0;display:flex;align-items:center;justify-content:space-between}
.ko-order-num{font-weight:800;font-size:16px;color:#1a2332}
.ko-table{font-size:12px;color:#666;margin-top:2px}
.ko-badge{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700}
.ko-badge.Pending{background:rgba(231,76,60,.12);color:#c0392b}
.ko-badge.Preparing{background:rgba(243,156,18,.15);color:#9a6a00}
.ko-badge.Ready{background:rgba(39,174,96,.12);color:#1a7a32}
.ko-items{padding:12px 16px}
.ko-item{display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid #f0f0f0;font-size:13px}
.ko-item:last-child{border-bottom:none}
.ko-item-qty{background:var(--orange);color:#fff;width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;flex-shrink:0}
.ko-time{font-size:11px;color:#888;padding:0 16px 8px;display:flex;align-items:center;gap:6px}
.ko-actions{padding:8px 16px 12px;display:flex;gap:8px}
.ko-btn{flex:1;padding:8px;border:none;border-radius:8px;cursor:pointer;font-family:'Cairo',sans-serif;font-size:13px;font-weight:600;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .2s}
.ko-btn-start{background:rgba(243,156,18,.15);color:#9a6a00}
.ko-btn-start:hover{background:rgba(243,156,18,.3)}
.ko-btn-ready{background:rgba(39,174,96,.15);color:#1a7a32}
.ko-btn-ready:hover{background:rgba(39,174,96,.3)}
.ko-btn-serve{background:rgba(21,101,192,.15);color:#1565C0}
.ko-btn-serve:hover{background:rgba(21,101,192,.3)}
.refresh-info{display:flex;align-items:center;gap:8px;color:#888;font-size:12px}
</style>
}
<div class="page-header">
  <h1><i class="fas fa-fire"></i> شاشة المطبخ</h1>
  <div class="refresh-info"><i class="fas fa-sync-alt" id="refreshIcon"></i> تحديث تلقائي كل 30 ثانية | <span id="lastUpdate">الآن</span></div>
</div>

@if (!orders.Any())
{
  <div style="text-align:center;padding:80px 20px;color:#888">
    <i class="fas fa-check-circle" style="font-size:64px;color:#27ae60;display:block;margin-bottom:16px"></i>
    <h2 style="font-size:20px;font-weight:700;color:#333;margin-bottom:8px">المطبخ فارغ</h2>
    <p>لا توجد طلبات معلقة حالياً</p>
  </div>
}
else
{
  <div class="kitchen-grid" id="kitchenGrid">
    @foreach (var o in orders)
    {
      string status = (string)o.status;
      string timeStr = "";
      if (o.created_at != null) {
        var elapsed = DateTime.Now - (DateTime)o.created_at;
        timeStr = elapsed.TotalMinutes < 60
          ? $"{(int)elapsed.TotalMinutes} دقيقة"
          : $"{(int)elapsed.TotalHours} ساعة";
      }
      <div class="ko-card status-@status" id="ko-@o.kitchen_order_id">
        <div class="ko-header">
          <div>
            <div class="ko-order-num">طلب #@o.order_id</div>
            <div class="ko-table"><i class="fas fa-table"></i> طاولة: @(string.IsNullOrEmpty((string?)o.table_number) ? "—" : (string)o.table_number)</div>
          </div>
          <span class="ko-badge @status">@(status == "Pending" ? "جديد" : status == "Preparing" ? "قيد التحضير" : "جاهز")</span>
        </div>
        <div class="ko-items">
          @if (o.Items != null)
          {
            foreach (var item in (IEnumerable<dynamic>)o.Items)
            {
              <div class="ko-item">
                <div class="ko-item-qty">@item.quantity</div>
                <span>@item.item_name</span>
              </div>
            }
          }
        </div>
        @if (!string.IsNullOrEmpty(timeStr))
        {
          <div class="ko-time"><i class="fas fa-clock"></i> منذ @timeStr</div>
        }
        <div class="ko-actions">
          @if (status == "Pending")
          {
            <button class="ko-btn ko-btn-start" onclick="updateStatus(@o.kitchen_order_id,'Preparing')"><i class="fas fa-play"></i> بدء التحضير</button>
          }
          @if (status == "Preparing")
          {
            <button class="ko-btn ko-btn-ready" onclick="updateStatus(@o.kitchen_order_id,'Ready')"><i class="fas fa-check"></i> جاهز</button>
          }
          @if (status == "Ready")
          {
            <button class="ko-btn ko-btn-serve" onclick="updateStatus(@o.kitchen_order_id,'Served')"><i class="fas fa-utensils"></i> تم التقديم</button>
          }
        </div>
      </div>
    }
  </div>
}

@section ExtraScripts {
<script>
async function updateStatus(id,status){
  const res=await apiPost('/kitchen/update_status',{kitchen_order_id:id,status});
  if(res.success){showToast('تم تحديث الحالة','success');setTimeout(()=>location.reload(),600);}
}
setInterval(()=>{
  document.getElementById('refreshIcon').style.transform='rotate(360deg)';
  document.getElementById('refreshIcon').style.transition='transform 0.5s';
  setTimeout(()=>{document.getElementById('refreshIcon').style.transform='';},500);
  location.reload();
},30000);
</script>
}
