@{
    ViewBag.Title = "آخر الطلبات";
    ViewBag.PageTitle = "آخر الطلبات";
    ViewBag.PageIcon = "fa-history";
    var orders = (IEnumerable<dynamic>)(ViewBag.Orders ?? new List<dynamic>());
}
<div class="page-header">
  <h1><i class="fas fa-history"></i> آخر الطلبات</h1>
  <a href="/pos" class="btn btn-primary"><i class="fas fa-cash-register"></i> نقطة البيع</a>
</div>
<div class="card">
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr><th>#</th><th>العميل</th><th>المجموع</th><th>طريقة الدفع</th><th>الكاشير</th><th>الحالة</th><th>التاريخ والوقت</th></tr>
      </thead>
      <tbody>
        @if (!orders.Any())
        {
          <tr><td colspan="7" style="text-align:center;padding:40px;color:#888"><i class="fas fa-inbox" style="font-size:32px;display:block;margin-bottom:10px"></i>لا توجد طلبات</td></tr>
        }
        else
        {
          foreach (var o in orders)
          {
            <tr>
              <td><strong>#@o.order_id</strong></td>
              <td>@o.customer_name</td>
              <td><strong>@((decimal)o.total_amount).ToString("N2")</strong></td>
              <td>
                @{
                  var pm = (string)o.payment_method;
                  if (pm == "Cash") { <span class="badge badge-success">نقدي</span> }
                  else if (pm == "Card") { <span class="badge badge-info">بطاقة</span> }
                  else { <span class="badge badge-secondary">@pm</span> }
                }
              </td>
              <td>@o.served_by</td>
              <td><span class="badge badge-success">مكتمل</span></td>
              <td style="font-size:12px;color:#888">@(((DateTime?)o.created_at)?.ToString("yyyy/MM/dd HH:mm") ?? "")</td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>
