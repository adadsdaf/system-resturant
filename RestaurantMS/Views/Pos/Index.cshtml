@{
    ViewBag.Title = "نقطة البيع";
    ViewBag.PageTitle = "نقطة البيع";
    ViewBag.PageIcon = "fa-cash-register";
    var categories = (IEnumerable<dynamic>)(ViewBag.Categories ?? new List<dynamic>());
    var items = (IEnumerable<dynamic>)(ViewBag.Items ?? new List<dynamic>());
    var taxRate = (double)(ViewBag.TaxRate ?? 0.0);
    var taxEnabled = (bool)(ViewBag.TaxEnabled ?? false);
    var currency = (string)(ViewBag.Currency ?? "ريال");
}
@section ExtraHead {
<style>
.pos-layout{display:grid;grid-template-columns:1fr 300px;grid-template-rows:auto 1fr;gap:0;height:calc(100vh - 58px - 48px);background:#1a2332;border-radius:14px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.2)}
.pos-menu-area{display:grid;grid-template-columns:200px 1fr;grid-template-rows:1fr;overflow:hidden}
.pos-categories{background:#1e2b3a;border-left:1px solid rgba(255,255,255,.08);overflow-y:auto;padding:12px 0}
.pos-cat-header{padding:10px 16px 8px;display:flex;align-items:center;gap:8px;color:#F7941D;font-size:13px;font-weight:700;border-bottom:1px solid rgba(255,255,255,.06);margin-bottom:6px}
.cat-btn{display:flex;align-items:center;gap:10px;width:100%;padding:11px 16px;background:none;border:none;cursor:pointer;color:rgba(255,255,255,.7);font-family:'Cairo',sans-serif;font-size:13px;font-weight:600;text-align:right;transition:all .2s;border-right:3px solid transparent}
.cat-btn:hover{background:rgba(255,255,255,.05);color:#fff}
.cat-btn.active{background:rgba(247,148,29,.12);color:#F7941D;border-right-color:#F7941D}
.cat-btn .cat-count{margin-right:auto;background:rgba(255,255,255,.12);color:rgba(255,255,255,.7);font-size:10px;padding:2px 7px;border-radius:10px}
.pos-items-grid{background:#f0f2f5;overflow-y:auto;padding:16px}
.items-section-title{font-size:12px;font-weight:700;color:#888;letter-spacing:1px;text-transform:uppercase;margin-bottom:12px;padding-bottom:6px;border-bottom:2px solid #e0e0e0;display:flex;align-items:center;gap:8px}
.items-section-title i{color:#F7941D}
.items-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-bottom:20px}
.item-card{background:#fff;border-radius:10px;overflow:hidden;cursor:pointer;transition:all .2s;box-shadow:0 2px 6px rgba(0,0,0,.06);border:2px solid transparent}
.item-card:hover{transform:translateY(-2px);box-shadow:0 4px 14px rgba(0,0,0,.12);border-color:#F7941D}
.item-card-body{padding:12px 10px 8px;text-align:center}
.item-name{font-size:12.5px;font-weight:700;color:#1a2332;margin-bottom:4px;line-height:1.3}
.item-desc{font-size:10px;color:#888;margin-bottom:6px;line-height:1.3;min-height:14px}
.item-price-btn{background:#4CAF50;color:#fff;border:none;border-radius:6px;padding:6px 0;width:100%;font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:4px;transition:background .2s}
.item-price-btn:hover{background:#388E3C}
.pos-cart{background:#1e2b3a;display:flex;flex-direction:column;border-right:1px solid rgba(255,255,255,.08);grid-row:1/-1}
.cart-header{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:space-between}
.cart-header h3{color:#fff;font-size:14px;font-weight:700;display:flex;align-items:center;gap:8px}
.cart-header h3 i{color:#F7941D}
.cart-order-info{padding:10px 14px;border-bottom:1px solid rgba(255,255,255,.06)}
.cart-info-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.cart-info-label{color:rgba(255,255,255,.5);font-size:11px;font-weight:600;white-space:nowrap}
.cart-info-input{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:#fff;font-family:'Cairo',sans-serif;font-size:12px;padding:5px 9px;border-radius:6px;flex:1;direction:rtl}
.cart-info-input:focus{outline:none;border-color:#F7941D}
.cart-items{flex:1;overflow-y:auto;padding:8px 0}
.cart-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:rgba(255,255,255,.25);gap:10px;padding:20px}
.cart-empty i{font-size:40px}
.cart-empty p{font-size:13px;text-align:center}
.cart-row{display:flex;align-items:center;gap:8px;padding:8px 12px;border-bottom:1px solid rgba(255,255,255,.05)}
.cart-row-info{flex:1;min-width:0}
.cart-row-name{color:#fff;font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cart-row-price{color:#F7941D;font-size:11px;font-weight:600}
.cart-qty{display:flex;align-items:center;gap:4px}
.qty-btn{width:24px;height:24px;background:rgba(255,255,255,.1);border:none;color:#fff;border-radius:5px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:background .2s}
.qty-btn:hover{background:#F7941D}
.qty-val{width:26px;text-align:center;color:#fff;font-size:13px;font-weight:700}
.cart-row-total{color:#fff;font-size:12px;font-weight:700;min-width:45px;text-align:left}
.cart-del-btn{background:none;border:none;color:rgba(255,255,255,.3);cursor:pointer;font-size:13px;transition:color .2s;padding:2px}
.cart-del-btn:hover{color:#e74c3c}
.cart-summary{border-top:1px solid rgba(255,255,255,.1);padding:12px 14px 8px;background:rgba(0,0,0,.15)}
.summary-row{display:flex;justify-content:space-between;align-items:center;padding:3px 0}
.summary-label{color:rgba(255,255,255,.6);font-size:12px}
.summary-val{color:#fff;font-size:12px;font-weight:600}
.summary-total .summary-label{color:#F7941D;font-size:14px;font-weight:700}
.summary-total .summary-val{color:#F7941D;font-size:18px;font-weight:800}
.discount-row{display:flex;align-items:center;gap:8px;padding:6px 0;border-top:1px solid rgba(255,255,255,.06);margin-top:4px}
.discount-label{color:rgba(255,255,255,.5);font-size:11px;font-weight:600}
.discount-input{width:55px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:#fff;font-family:'Cairo',sans-serif;font-size:12px;padding:4px 6px;border-radius:5px;text-align:center}
.discount-input:focus{outline:none;border-color:#F7941D}
.cart-actions{padding:10px 12px;display:flex;flex-direction:column;gap:8px}
.payment-methods{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:4px}
.pay-method-btn{padding:7px 4px;border:1.5px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:rgba(255,255,255,.7);border-radius:7px;cursor:pointer;font-family:'Cairo',sans-serif;font-size:11px;font-weight:600;display:flex;flex-direction:column;align-items:center;gap:3px;transition:all .2s}
.pay-method-btn i{font-size:14px}
.pay-method-btn.selected{border-color:#F7941D;background:rgba(247,148,29,.15);color:#F7941D}
.btn-checkout{width:100%;padding:14px;background:linear-gradient(135deg,#F7941D,#e07c08);color:#fff;border:none;border-radius:10px;font-family:'Cairo',sans-serif;font-size:16px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .2s;box-shadow:0 4px 14px rgba(247,148,29,.3)}
.btn-checkout:hover{transform:translateY(-1px)}
.btn-checkout:disabled{opacity:.5;cursor:not-allowed;transform:none}
.btn-clear{width:100%;padding:8px;background:rgba(220,53,69,.15);color:#e74c3c;border:1px solid rgba(220,53,69,.3);border-radius:8px;font-family:'Cairo',sans-serif;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .2s}
.receipt-box{font-family:'Cairo',monospace;background:#fff;border:1px solid #ddd;border-radius:8px;padding:16px;font-size:13px;line-height:1.8}
.receipt-title{text-align:center;font-size:16px;font-weight:700;margin-bottom:6px}
.receipt-sub{text-align:center;font-size:11px;color:#666;margin-bottom:12px;border-bottom:1px dashed #ccc;padding-bottom:8px}
.receipt-row{display:flex;justify-content:space-between}
.receipt-total{font-weight:800;font-size:15px;border-top:2px solid #333;padding-top:6px;margin-top:6px}
.receipt-footer{text-align:center;font-size:11px;color:#888;margin-top:10px;padding-top:8px;border-top:1px dashed #ccc}
</style>
}

<div class="pos-layout">
  <div class="pos-menu-area">
    <div class="pos-categories">
      <div class="pos-cat-header"><i class="fas fa-th-large"></i> قائمة الطعام</div>
      <button class="cat-btn active" data-cat="all" onclick="filterCategory('all',this)">
        <i class="fas fa-border-all"></i> الكل
        <span class="cat-count">@items.Count()</span>
      </button>
      @foreach (var cat in categories)
      {
        int catId = (int)cat.category_id;
        int catCount = items.Count(i => (int)i.category_id == catId);
        <button class="cat-btn" data-cat="@catId" onclick="filterCategory('@catId',this)">
          <i class="fas fa-tag"></i> @cat.category_name
          <span class="cat-count">@catCount</span>
        </button>
      }
    </div>
    <div class="pos-items-grid" id="itemsGrid">
      @foreach (var cat in categories)
      {
        int catId = (int)cat.category_id;
        var catItems = items.Where(i => (int)i.category_id == catId);
        if (catItems.Any())
        {
          <div class="items-section cat-section" data-cat="@catId">
            <div class="items-section-title"><i class="fas fa-tag"></i> @cat.category_name</div>
            <div class="items-grid">
              @foreach (var item in catItems)
              {
                string itemName = ((string)item.item_name).Replace("'", "\\'");
                double price = (double)(decimal)item.price;
                string desc = item.description != null ? ((string)item.description).Length > 30 ? ((string)item.description)[..30] : (string)item.description : "";
                <div class="item-card" onclick="addToCart(@item.item_id,'@itemName',@price.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))">
                  <div class="item-card-body">
                    <div class="item-name">@item.item_name</div>
                    <div class="item-desc">@desc</div>
                    <button class="item-price-btn" onclick="event.stopPropagation();addToCart(@item.item_id,'@itemName',@price.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))">
                      <i class="fas fa-plus-circle"></i> @((decimal)item.price).ToString("N0")
                    </button>
                  </div>
                </div>
              }
            </div>
          </div>
        }
      }
    </div>
  </div>

  <div class="pos-cart">
    <div class="cart-header">
      <h3><i class="fas fa-shopping-cart"></i> الطلب الحالي</h3>
      <span style="background:rgba(247,148,29,.2);color:#F7941D;padding:3px 10px;border-radius:10px;font-size:11px;font-weight:700" id="cartCount">0 صنف</span>
    </div>
    <div class="cart-order-info">
      <div class="cart-info-row">
        <span class="cart-info-label"><i class="fas fa-user" style="color:#F7941D"></i> العميل:</span>
        <input type="text" class="cart-info-input" id="customerName" placeholder="اسم العميل (اختياري)">
      </div>
      <div class="cart-info-row">
        <span class="cart-info-label"><i class="fas fa-table" style="color:#F7941D"></i> طاولة:</span>
        <input type="text" class="cart-info-input" id="tableNumber" placeholder="رقم الطاولة">
      </div>
      <div class="cart-info-row">
        <span class="cart-info-label"><i class="fas fa-phone" style="color:#F7941D"></i> هاتف:</span>
        <input type="text" class="cart-info-input" id="customerPhone" placeholder="ابحث برقم الهاتف" oninput="searchCustomer(this.value)">
      </div>
    </div>
    <div class="cart-items" id="cartItems">
      <div class="cart-empty" id="cartEmpty">
        <i class="fas fa-shopping-cart"></i>
        <p>العربة فارغة<br>أضف أصنافاً من القائمة</p>
      </div>
    </div>
    <div class="cart-summary" id="cartSummary" style="display:none">
      <div class="summary-row"><span class="summary-label">الأصناف</span><span class="summary-val" id="sumCount">0</span></div>
      <div class="summary-row"><span class="summary-label">المجموع</span><span class="summary-val" id="sumSubtotal">0.00</span></div>
      <div class="discount-row">
        <span class="discount-label"><i class="fas fa-percent"></i> خصم %:</span>
        <input type="number" class="discount-input" id="discountPct" value="0" min="0" max="100" oninput="updateSummary()">
        <span class="summary-label" style="margin-right:auto">خصم:</span>
        <span class="summary-val" id="sumDiscount" style="color:#e74c3c">0.00</span>
      </div>
      @if (taxEnabled)
      {
        <div class="summary-row">
          <span class="summary-label">ضريبة @taxRate.ToString("N0")%</span>
          <span class="summary-val" id="sumTax">0.00</span>
        </div>
      }
      <div class="summary-row summary-total" style="margin-top:6px;padding-top:6px;border-top:1px solid rgba(247,148,29,.3)">
        <span class="summary-label">الإجمالي</span>
        <span class="summary-val" id="sumTotal">0.00</span>
      </div>
    </div>
    <div class="cart-actions">
      <div class="payment-methods">
        <button class="pay-method-btn selected" data-method="Cash" onclick="selectPayMethod('Cash',this)"><i class="fas fa-money-bill-wave"></i> نقدي</button>
        <button class="pay-method-btn" data-method="Card" onclick="selectPayMethod('Card',this)"><i class="fas fa-credit-card"></i> بطاقة</button>
        <button class="pay-method-btn" data-method="Transfer" onclick="selectPayMethod('Transfer',this)"><i class="fas fa-university"></i> تحويل</button>
      </div>
      <button class="btn-checkout" id="checkoutBtn" onclick="checkout()" disabled><i class="fas fa-check-circle"></i> إتمام الطلب</button>
      <button class="btn-clear" onclick="clearCart()"><i class="fas fa-times"></i> إلغاء الطلب</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="receiptModal">
  <div class="modal-box" style="max-width:400px">
    <div class="modal-header">
      <h3><i class="fas fa-receipt"></i> الفاتورة</h3>
      <button class="modal-close" onclick="closeModal('receiptModal')">×</button>
    </div>
    <div class="modal-body"><div class="receipt-box" id="receiptContent"></div></div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="window.print()"><i class="fas fa-print"></i> طباعة</button>
      <button class="btn btn-success" onclick="closeModal('receiptModal');clearCart()"><i class="fas fa-check"></i> طلب جديد</button>
    </div>
  </div>
</div>

@section ExtraScripts {
<script>
const TAX_RATE=@taxRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
const TAX_ENABLED=@(taxEnabled ? "true" : "false");
const CURRENCY='@currency';
let cart=[],payMethod='Cash',customerId=null;

function filterCategory(catId,btn){
  document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.cat-section').forEach(s=>{s.style.display=(catId==='all'||s.dataset.cat==catId)?'':'none';});
}
function addToCart(id,name,price){
  const ex=cart.find(i=>i.item_id==id);
  if(ex){ex.quantity++;}else{cart.push({item_id:id,name,price,quantity:1});}
  renderCart();showToast(name+' تم الإضافة','success',1500);
}
function removeFromCart(idx){cart.splice(idx,1);renderCart();}
function changeQty(idx,delta){cart[idx].quantity+=delta;if(cart[idx].quantity<=0)cart.splice(idx,1);renderCart();}
function clearCart(){
  cart=[];document.getElementById('discountPct').value=0;
  document.getElementById('customerName').value='';document.getElementById('tableNumber').value='';
  document.getElementById('customerPhone').value='';customerId=null;renderCart();
}
function renderCart(){
  const container=document.getElementById('cartItems'),empty=document.getElementById('cartEmpty'),
        summary=document.getElementById('cartSummary'),countBadge=document.getElementById('cartCount'),
        checkBtn=document.getElementById('checkoutBtn');
  if(cart.length===0){
    empty.style.display='';summary.style.display='none';checkBtn.disabled=true;
    countBadge.textContent='0 صنف';container.innerHTML='';container.appendChild(empty);return;
  }
  empty.style.display='none';summary.style.display='';checkBtn.disabled=false;
  countBadge.textContent=cart.length+' صنف';
  let html='';
  cart.forEach((item,idx)=>{
    html+=`<div class="cart-row">
      <div class="cart-row-info"><div class="cart-row-name">${item.name}</div><div class="cart-row-price">${item.price.toFixed(2)} × ${item.quantity}</div></div>
      <div class="cart-qty">
        <button class="qty-btn" onclick="changeQty(${idx},-1)">−</button>
        <span class="qty-val">${item.quantity}</span>
        <button class="qty-btn" onclick="changeQty(${idx},1)">+</button>
      </div>
      <div class="cart-row-total">${(item.price*item.quantity).toFixed(2)}</div>
      <button class="cart-del-btn" onclick="removeFromCart(${idx})"><i class="fas fa-times"></i></button>
    </div>`;
  });
  container.innerHTML=html;updateSummary();
}
function updateSummary(){
  const subtotal=cart.reduce((s,i)=>s+i.price*i.quantity,0);
  const disc=parseFloat(document.getElementById('discountPct').value)||0;
  const discAmt=subtotal*disc/100,taxable=subtotal-discAmt;
  const taxAmt=TAX_ENABLED?taxable*TAX_RATE/100:0,total=taxable+taxAmt;
  document.getElementById('sumCount').textContent=cart.reduce((s,i)=>s+i.quantity,0);
  document.getElementById('sumSubtotal').textContent=subtotal.toFixed(2)+' '+CURRENCY;
  document.getElementById('sumDiscount').textContent=discAmt.toFixed(2)+' '+CURRENCY;
  const taxEl=document.getElementById('sumTax');if(taxEl)taxEl.textContent=taxAmt.toFixed(2)+' '+CURRENCY;
  document.getElementById('sumTotal').textContent=total.toFixed(2)+' '+CURRENCY;
}
function selectPayMethod(method,btn){
  payMethod=method;document.querySelectorAll('.pay-method-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
}
async function checkout(){
  if(cart.length===0)return;
  const btn=document.getElementById('checkoutBtn');
  btn.disabled=true;btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> جاري الحفظ...';
  const data={cart,customer_name:document.getElementById('customerName').value||'زبون',
    customer_id:customerId,discount_pct:parseFloat(document.getElementById('discountPct').value)||0,
    payment_method:payMethod,table_number:document.getElementById('tableNumber').value,notes:''};
  const res=await apiPost('/pos/save_order',data);
  if(res.success){showReceipt(res);}
  else{showToast('خطأ: '+res.error,'error');btn.disabled=false;btn.innerHTML='<i class="fas fa-check-circle"></i> إتمام الطلب';}
}
function showReceipt(order){
  const now=new Date(),dateStr=now.toLocaleDateString('ar-SA')+' '+now.toLocaleTimeString('ar-SA');
  const custName=document.getElementById('customerName').value||'زبون';
  const tableNum=document.getElementById('tableNumber').value||'—';
  const pmLabel={Cash:'نقدي',Card:'بطاقة',Transfer:'تحويل'}[payMethod]||payMethod;
  let itemsHtml=cart.map(i=>`<div class="receipt-row"><span>${i.name} × ${i.quantity}</span><span>${(i.price*i.quantity).toFixed(2)}</span></div>`).join('');
  document.getElementById('receiptContent').innerHTML=`
    <div class="receipt-title">🍽 فاتورة مطعم</div>
    <div class="receipt-sub">طلب #${order.order_id} | ${dateStr}<br>العميل: ${custName} | طاولة: ${tableNum}</div>
    <div style="margin-bottom:8px">${itemsHtml}</div>
    <div class="receipt-row" style="border-top:1px dashed #ccc;padding-top:6px"><span>المجموع</span><span>${order.subtotal.toFixed(2)}</span></div>
    ${order.discount_amount>0?`<div class="receipt-row" style="color:#e74c3c"><span>خصم</span><span>-${order.discount_amount.toFixed(2)}</span></div>`:''}
    ${order.tax_amount>0?`<div class="receipt-row" style="color:#888"><span>ضريبة</span><span>${order.tax_amount.toFixed(2)}</span></div>`:''}
    <div class="receipt-row receipt-total"><span>الإجمالي</span><span>${order.total_amount.toFixed(2)} ${CURRENCY}</span></div>
    <div class="receipt-row" style="margin-top:6px;color:#666;font-size:12px"><span>طريقة الدفع</span><span>${pmLabel}</span></div>
    <div class="receipt-footer">شكراً لزيارتكم<br>إتقان سوفت للبرمجيات</div>`;
  openModal('receiptModal');showToast('تم حفظ الطلب بنجاح!','success');
}
async function searchCustomer(phone){
  if(phone.length<8)return;
  const res=await fetch('/pos/search_customer?phone='+phone);
  const data=await res.json();
  if(data){document.getElementById('customerName').value=data.full_name;customerId=data.customer_id;showToast('تم العثور على العميل: '+data.full_name,'info');}
}
</script>
}
