@{
    Layout = null;
    ViewBag.Title = "تسجيل الدخول";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>تسجيل الدخول - نظام إدارة المطعم</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Cairo',sans-serif;background:linear-gradient(135deg,#1a2332 0%,#1565C0 50%,#0d47a1 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;direction:rtl;padding:20px;position:relative;overflow:hidden}
body::before{content:'';position:absolute;width:600px;height:600px;border-radius:50%;background:rgba(247,148,29,.08);top:-200px;left:-200px}
body::after{content:'';position:absolute;width:400px;height:400px;border-radius:50%;background:rgba(247,148,29,.06);bottom:-100px;right:-100px}
.login-card{background:#fff;border-radius:20px;width:100%;max-width:440px;box-shadow:0 25px 60px rgba(0,0,0,.3);overflow:hidden;position:relative;z-index:1}
.login-header{background:linear-gradient(135deg,#1a2332,#243044);padding:36px 40px 30px;text-align:center;position:relative}
.login-header::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#F7941D,#1565C0)}
.logo-wrap{width:80px;height:80px;background:#fff;border-radius:20px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(0,0,0,.2);overflow:hidden}
.logo-wrap img{width:70px;height:70px;object-fit:contain}
.logo-icon{font-size:36px;color:#F7941D}
.login-header h1{color:#fff;font-size:22px;font-weight:800;margin-bottom:4px}
.login-header p{color:rgba(255,255,255,.6);font-size:13px}
.brand-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(247,148,29,.15);border:1px solid rgba(247,148,29,.3);color:#F7941D;border-radius:20px;padding:3px 12px;font-size:11px;font-weight:700;margin-top:10px}
.login-body{padding:32px 40px}
.form-group{margin-bottom:18px}
.form-label{display:block;font-size:12px;font-weight:700;color:#555;margin-bottom:6px;letter-spacing:.3px}
.input-wrap{position:relative;display:flex;align-items:center}
.input-wrap i{position:absolute;right:13px;color:#aaa;font-size:14px}
.input-wrap input{width:100%;padding:11px 40px 11px 14px;border:2px solid #e8e8e8;border-radius:10px;font-family:'Cairo',sans-serif;font-size:14px;direction:rtl;color:#1a2332;transition:border .2s;background:#fafafa}
.input-wrap input:focus{outline:none;border-color:#F7941D;background:#fff;box-shadow:0 0 0 4px rgba(247,148,29,.1)}
.error-msg{background:rgba(220,53,69,.08);border:1px solid rgba(220,53,69,.2);color:#c0392b;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:16px;display:flex;align-items:center;gap:8px}
.btn-login{width:100%;padding:13px;background:linear-gradient(135deg,#F7941D,#e07c08);color:#fff;border:none;border-radius:10px;font-family:'Cairo',sans-serif;font-size:16px;font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 14px rgba(247,148,29,.35)}
.btn-login:hover{background:linear-gradient(135deg,#e07c08,#c96a00);transform:translateY(-1px);box-shadow:0 6px 20px rgba(247,148,29,.45)}
.default-cred{text-align:center;margin-top:18px;font-size:12px;color:#999;background:#f8f9fa;border-radius:8px;padding:10px;border:1px dashed #ddd}
.default-cred strong{color:#1565C0}
</style>
</head>
<body>
<div class="login-card">
  <div class="login-header">
    <div class="logo-wrap">
      <img src="/static/logo.png" alt="Logo" onerror="this.outerHTML='<i class=\'fas fa-utensils logo-icon\'></i>'">
    </div>
    <h1>نظام إدارة المطعم</h1>
    <p>نقاط البيع والإدارة المتكاملة</p>
    <div class="brand-badge"><i class="fas fa-shield-alt"></i> إتقان سوفت</div>
  </div>
  <div class="login-body">
    @if (ViewBag.Error != null)
    {
      <div class="error-msg"><i class="fas fa-exclamation-circle"></i> @ViewBag.Error</div>
    }
    <form method="POST" action="/login">
      <div class="form-group">
        <label class="form-label">اسم المستخدم</label>
        <div class="input-wrap">
          <i class="fas fa-user"></i>
          <input type="text" name="username" placeholder="أدخل اسم المستخدم" required autocomplete="username">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">كلمة المرور</label>
        <div class="input-wrap">
          <i class="fas fa-lock"></i>
          <input type="password" name="password" placeholder="أدخل كلمة المرور" required autocomplete="current-password">
        </div>
      </div>
      <button type="submit" class="btn-login"><i class="fas fa-sign-in-alt"></i> تسجيل الدخول</button>
    </form>
    <div class="default-cred">
      بيانات الدخول الافتراضية:<br>
      المستخدم: <strong>admin</strong> &nbsp;|&nbsp; كلمة المرور: <strong>admin123</strong>
      <br><span style="color:#7c3aed;font-size:11px;margin-top:4px;display:block;">
        <i class="fas fa-shield-alt"></i>
        المالك: <strong>owner</strong> &nbsp;|&nbsp; كلمة المرور: <strong>owner2025</strong>
      </span>
    </div>
  </div>
</div>
</body>
</html>
